    valuesets:compliance "regulatory compliance" ;
    valuesets:geographic "domestic market only" ;
    valuesets:proximity "geographic proximity" ;
    valuesets:responsiveness "local responsiveness" ;
    valuesets:support "domestic economy support" .

<https://w3id.org/valuesets/SourcingStrategyEnum#DUAL_SOURCING> a owl:Class ;
