    valuesets:complexity "increased complexity" ;
    valuesets:cost "cost optimization" ;
    valuesets:geographic "global geographic scope" ;
    valuesets:risk "global supply risks" .

<https://w3id.org/valuesets/SourcingStrategyEnum#INSOURCING> a owl:Class ;
