<https://w3id.org/valuesets/HydrogenStorageMethod#METAL_HYDRIDE> a owl:Class ;
    rdfs:label "METAL_HYDRIDE" ;
    dcterms:title "Metal Hydride Storage" ;
    rdfs:subClassOf valuesets:HydrogenStorageMethod ;
