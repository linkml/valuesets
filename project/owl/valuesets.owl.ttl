MmusDv:0000009 a owl:Class ;
    rdfs:label "BLASTOCYST_STAGE" ;
    dcterms:title "Theiler stage 05" ;
    rdfs:subClassOf valuesets:MouseDevelopmentalStage ;
    skos:definition "Embryonic blastula stage defined by a zona free blastocyst (zona pellucida absent). Embryonic age 4 dpc." .

MmusDv:0000013 a owl:Class ;
    rdfs:label "GASTRULA_STAGE" ;
    dcterms:title "gastrula stage" ;
    rdfs:subClassOf valuesets:MouseDevelopmentalStage ;
    skos:definition "Embryonic stage defined by complex and coordinated series of cellular movements that occurs at the end of cleavage." .

MmusDv:0000017 a owl:Class ;
    rdfs:label "NEURULA_STAGE" ;
    dcterms:title "Theiler stage 11" ;
    rdfs:subClassOf valuesets:MouseDevelopmentalStage ;
    skos:definition "Embryonic stage called presomite stage and defined by the formation of the neural plate. This stage starts the emergence of the central nervous system at embryonic age 7.5 dpc." .

MmusDv:0000018 a owl:Class ;
    rdfs:label "ORGANOGENESIS_STAGE" ;
    dcterms:title "organogenesis stage" ;
    rdfs:subClassOf valuesets:MouseDevelopmentalStage ;
    skos:definition "Embryonic stage at which the ectoderm, endoderm, and mesoderm develop into the internal organs of the organism." .

MmusDv:0000023 a owl:Class ;
    rdfs:label "E9_5" ;
    dcterms:title "Theiler stage 16" ;
    rdfs:subClassOf valuesets:MouseDevelopmentalStage ;
    skos:definition "Embryonic day 9.5 - organogenesis stage with visible hind limb buds. Between Theiler stages 15 and 16." .

MmusDv:0000029 a owl:Class ;
    rdfs:label "E14_5" ;
    dcterms:title "Theiler stage 22" ;
    rdfs:subClassOf valuesets:MouseDevelopmentalStage ;
    skos:definition "Embryonic day 14.5 - late organogenesis with clearly visible fingers and long bones of the limbs present." .

MmusDv:0000036 a owl:Class ;
    rdfs:label "P0_NEWBORN" ;
    dcterms:title "Theiler stage 27" ;
    rdfs:subClassOf valuesets:MouseDevelopmentalStage ;
    skos:definition "Stage that refers to the newborn mouse, aged E19-20, P0. Used for postnatal days 0 through 3." .

MmusDv:0000135 a owl:Class ;
    rdfs:label "AGED_12_MONTHS" ;
    dcterms:title "middle aged stage" ;
    rdfs:subClassOf valuesets:MouseDevelopmentalStage ;
    skos:definition "Middle aged stage for mice over 10 and under 18 months old. Shows progressive age-related changes." .

MmusDv:0000141 a owl:Class ;
    rdfs:label "P21_WEANING" ;
    dcterms:title "2-week-old stage" ;
    rdfs:subClassOf valuesets:MouseDevelopmentalStage ;
    skos:definition "Weaning stage at approximately 21-22 days old. Transition from nursing to independent feeding." .

MmusDv:0000151 a owl:Class ;
    rdfs:label "P42_JUVENILE" ;
    dcterms:title "6-week-old stage" ;
    rdfs:subClassOf valuesets:MouseDevelopmentalStage ;
    skos:definition "Prime adult stage at 6 weeks (42 days) old. Commonly considered the milestone for sexual maturity." .

MmusDv:0000154 a owl:Class ;
    rdfs:label "P56_ADULT" ;
    dcterms:title "8-week-old stage" ;
    rdfs:subClassOf valuesets:MouseDevelopmentalStage ;
    skos:definition "Adult stage at 8 weeks (56 days) old. Fully mature adult mouse." .

