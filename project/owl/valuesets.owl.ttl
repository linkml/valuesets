    valuesets:temperature_min_c 374 .

<https://w3id.org/valuesets/GeothermalSystemType#ADVANCED_GEOTHERMAL_SYSTEM> a owl:Class ;
    rdfs:label "ADVANCED_GEOTHERMAL_SYSTEM" ;
    dcterms:title "Advanced Geothermal System (AGS)" ;
    rdfs:subClassOf valuesets:GeothermalSystemType ;
    skos:altLabel "AGS",
        "Closed-Loop Geothermal" ;
    skos:definition "Closed-loop geothermal systems that circulate working fluid through wellbores to extract heat conductively without reservoir stimulation." ;
    valuesets:closed_loop true .

<https://w3id.org/valuesets/GeothermalSystemType#ENHANCED_GEOTHERMAL_SYSTEM> a owl:Class ;
    rdfs:label "ENHANCED_GEOTHERMAL_SYSTEM" ;
    dcterms:title "Enhanced Geothermal System (EGS)" ;
    rdfs:subClassOf valuesets:GeothermalSystemType ;
    skos:altLabel "EGS",
        "Engineered Geothermal System" ;
    skos:definition "Engineered reservoirs created to extract heat from low permeability geothermal resources through stimulation methods." ;
    valuesets:requires_stimulation true .

<https://w3id.org/valuesets/GeothermalSystemType#GEOPRESSURED> a owl:Class ;
    rdfs:label "GEOPRESSURED" ;
    dcterms:title "Geopressured System" ;
    rdfs:subClassOf valuesets:GeothermalSystemType ;
    skos:definition "Deep sedimentary formations with abnormally high fluid pressure containing hot brine and dissolved methane." ;
    valuesets:methane_recovery true .

<https://w3id.org/valuesets/GeothermalSystemType#GROUND_SOURCE_HEAT_PUMP> a owl:Class ;
