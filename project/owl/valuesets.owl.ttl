    valuesets:classification "Basic" ;
    valuesets:uptime_guarantee "99.671%" .

<https://w3id.org/valuesets/DataCenterTierLevel#TIER_II> a owl:Class ;
    rdfs:label "TIER_II" ;
    rdfs:subClassOf valuesets:DataCenterTierLevel ;
    skos:definition "Redundant capacity components - single non-redundant distribution path with redundant components" ;
    valuesets:classification "Redundant Components" ;
    valuesets:uptime_guarantee "99.741%" .

<https://w3id.org/valuesets/DataCenterTierLevel#TIER_III> a owl:Class ;
    rdfs:label "TIER_III" ;
    rdfs:subClassOf valuesets:DataCenterTierLevel ;
    skos:definition "Concurrently maintainable - multiple independent distribution paths with redundant components" ;
    valuesets:classification "Concurrently Maintainable" ;
    valuesets:uptime_guarantee "99.982%" .

<https://w3id.org/valuesets/DataCenterTierLevel#TIER_IV> a owl:Class ;
    rdfs:label "TIER_IV" ;
    rdfs:subClassOf valuesets:DataCenterTierLevel ;
    skos:definition "Fault tolerant - multiple independent distribution paths with redundant components, fault tolerant" ;
    valuesets:classification "Fault Tolerant" ;
    valuesets:uptime_guarantee "99.995%" .

