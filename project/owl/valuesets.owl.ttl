HP:0012832 a owl:Class ;
    rdfs:label "BILATERAL" ;
    rdfs:subClassOf valuesets:LateralityEnum ;
    skos:definition "Both sides" ;
    valuesets:note "Affecting both left and right" .

HP:0012833 a owl:Class ;
    rdfs:label "UNILATERAL" ;
    rdfs:subClassOf valuesets:LateralityEnum ;
    skos:definition "One side (unspecified which)" ;
    valuesets:note "Affecting only one side" .

HP:0012834 a owl:Class ;
    rdfs:label "RIGHT" ;
    rdfs:subClassOf valuesets:LateralityEnum ;
