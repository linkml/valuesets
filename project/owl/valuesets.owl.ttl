<https://w3id.org/valuesets/ExperimentalDesignMethodType#ACTIVE_LEARNING> a owl:Class ;
    rdfs:label "ACTIVE_LEARNING" ;
    rdfs:subClassOf valuesets:ExperimentalDesignMethodType ;
    skos:definition "Machine learning approach that iteratively selects the most informative experiments to perform" ;
    valuesets:approach "query-based learning from unlabeled data" .

<https://w3id.org/valuesets/ExperimentalDesignMethodType#BAYESIAN_OPTIMIZATION> a owl:Class ;
    rdfs:label "BAYESIAN_OPTIMIZATION" ;
    rdfs:subClassOf valuesets:ExperimentalDesignMethodType ;
    skos:definition "Probabilistic model-based optimization using Bayesian inference to guide experimental selection" ;
    valuesets:approach "surrogate model with acquisition function" .

<https://w3id.org/valuesets/ExperimentalDesignMethodType#DESIGN_OF_EXPERIMENTS> a owl:Class ;
    rdfs:label "DESIGN_OF_EXPERIMENTS" ;
    rdfs:subClassOf valuesets:ExperimentalDesignMethodType ;
    skos:definition "Classical statistical methods for planning experiments including factorial and response surface designs" ;
    valuesets:approaches "full factorial, fractional factorial, Box-Behnken, central composite" .

<https://w3id.org/valuesets/ExperimentalDesignMethodType#EVOLUTIONARY_ALGORITHM> a owl:Class ;
    rdfs:label "EVOLUTIONARY_ALGORITHM" ;
    rdfs:subClassOf valuesets:ExperimentalDesignMethodType ;
    skos:definition "Optimization method inspired by biological evolution using mutation, crossover, and selection" ;
    valuesets:approach "population-based metaheuristic" .

<https://w3id.org/valuesets/ExperimentalDesignMethodType#GRID_SEARCH> a owl:Class ;
    rdfs:label "GRID_SEARCH" ;
    rdfs:subClassOf valuesets:ExperimentalDesignMethodType ;
    skos:definition "Systematic exploration of parameter space using a regular grid of experimental conditions" ;
    valuesets:approach "exhaustive grid evaluation" .

<https://w3id.org/valuesets/ExperimentalDesignMethodType#LATIN_HYPERCUBE_SAMPLING> a owl:Class ;
    rdfs:label "LATIN_HYPERCUBE_SAMPLING" ;
    rdfs:subClassOf valuesets:ExperimentalDesignMethodType ;
    skos:definition "Statistical sampling method that ensures even coverage of each parameter dimension" ;
    valuesets:approach "stratified random sampling" .

<https://w3id.org/valuesets/ExperimentalDesignMethodType#MULTI_OBJECTIVE_OPTIMIZATION> a owl:Class ;
    rdfs:label "MULTI_OBJECTIVE_OPTIMIZATION" ;
    rdfs:subClassOf valuesets:ExperimentalDesignMethodType ;
    skos:definition "Optimization approach that simultaneously considers multiple competing objectives" ;
    valuesets:approach "Pareto-optimal solution search" .

<https://w3id.org/valuesets/ExperimentalDesignMethodType#RANDOM_SEARCH> a owl:Class ;
    rdfs:label "RANDOM_SEARCH" ;
    rdfs:subClassOf valuesets:ExperimentalDesignMethodType ;
    skos:definition "Experimental design using random sampling of the parameter space" ;
    valuesets:approach "random sampling" .

<https://w3id.org/valuesets/ExperimentalDesignMethodType#REINFORCEMENT_LEARNING> a owl:Class ;
    rdfs:label "REINFORCEMENT_LEARNING" ;
    rdfs:subClassOf valuesets:ExperimentalDesignMethodType ;
    skos:definition "Machine learning approach where an agent learns optimal experimental strategies through trial and reward" ;
    valuesets:approach "reward-based sequential decision making" .

