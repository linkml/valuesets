<https://w3id.org/valuesets/HydrogeologyWellType#EXTRACTION_WELL> a owl:Class ;
    rdfs:label "EXTRACTION_WELL" ;
    rdfs:subClassOf valuesets:HydrogeologyWellType ;
    skos:definition "A well used to remove contaminated groundwater as part of remediation activities" .

<https://w3id.org/valuesets/HydrogeologyWellType#GEOTHERMAL_WELL> a owl:Class ;
    rdfs:label "GEOTHERMAL_WELL" ;
    rdfs:subClassOf valuesets:HydrogeologyWellType ;
    skos:broadMatch ENVO:01000002 ;
    skos:definition "A well drilled to access geothermal resources for energy production or direct use" .

<https://w3id.org/valuesets/HydrogeologyWellType#INJECTION_WELL> a owl:Class ;
    rdfs:label "INJECTION_WELL" ;
    rdfs:subClassOf valuesets:HydrogeologyWellType ;
    skos:definition "A well used to inject fluids into the subsurface for disposal, storage, or aquifer recharge" .

<https://w3id.org/valuesets/HydrogeologyWellType#MONITORING_WELL> a owl:Class ;
    rdfs:label "MONITORING_WELL" ;
    rdfs:subClassOf valuesets:HydrogeologyWellType ;
