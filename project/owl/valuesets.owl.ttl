<https://w3id.org/valuesets/IPCCConfidenceLevel#VERY_HIGH_CONFIDENCE> a owl:Class ;
    rdfs:label "VERY_HIGH_CONFIDENCE" ;
    rdfs:subClassOf valuesets:IPCCConfidenceLevel ;
    skos:closeMatch NCIt:C129479 ;
    skos:definition "Very high confidence in the validity of a finding." .

<https://w3id.org/valuesets/IPCCConfidenceLevel#VERY_LOW_CONFIDENCE> a owl:Class ;
