    rdfs:subClassOf valuesets:DataCenterCoolingType ;
    skos:definition "Cooling by submerging server hardware in a thermally conductive dielectric liquid" .

<https://w3id.org/valuesets/DataCenterCoolingType#LIQUID_COOLING> a owl:Class ;
    rdfs:label "LIQUID_COOLING" ;
    rdfs:subClassOf valuesets:DataCenterCoolingType ;
