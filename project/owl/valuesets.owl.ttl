<http://id.loc.gov/vocabulary/preservation/copyrightStatus/cpr> a owl:Class ;
    rdfs:label "COPYRIGHTED" ;
    rdfs:subClassOf valuesets:CopyrightStatus ;
    skos:definition "The object is protected by copyright." .

<http://id.loc.gov/vocabulary/preservation/copyrightStatus/pub> a owl:Class ;
    rdfs:label "PUBLIC_DOMAIN" ;
    dcterms:title "Public Domain" ;
    rdfs:subClassOf valuesets:CopyrightStatus ;
    skos:definition """The object is not protected by copyright, either because copyright
has expired, was never applicable, or has been waived.
""" .

<http://id.loc.gov/vocabulary/preservation/copyrightStatus/unk> a owl:Class ;
    rdfs:label "UNKNOWN" ;
    rdfs:subClassOf valuesets:CopyrightStatus ;
    skos:definition "The copyright status cannot be determined." .

<http://id.loc.gov/vocabulary/preservation/cryptographicHashFunctions/adl> a owl:Class ;
    rdfs:label "ADLER_32" ;
    dcterms:title "Adler-32" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """A checksum algorithm developed by Mark Adler. Faster than CRC32
but with weaker error detection. Used in zlib compression.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_adler32 ;
    valuesets:output_bits 32 ;
    valuesets:security_level "non-cryptographic" .

<http://id.loc.gov/vocabulary/preservation/cryptographicHashFunctions/crc> a owl:Class ;
    rdfs:label "CRC32" ;
    dcterms:title "CRC32" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """Cyclic Redundancy Check with 32-bit output. Used for error detection
in network transmissions and storage. Not cryptographically secure.
""" ;
    valuesets:output_bits 32 ;
    valuesets:security_level "non-cryptographic" .

<http://id.loc.gov/vocabulary/preservation/cryptographicHashFunctions/hav> a owl:Class ;
    rdfs:label "HAVAL" ;
    dcterms:title "HAVAL" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """A cryptographic hash function that can produce hash values of
128, 160, 192, 224, or 256 bits. Variable number of rounds.
""" ;
    valuesets:output_bits "variable" ;
    valuesets:security_level "deprecated" .

<http://id.loc.gov/vocabulary/preservation/cryptographicHashFunctions/md2> a owl:Class ;
    rdfs:label "MD2" ;
    dcterms:title "MD2" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """Message Digest 2 algorithm producing a 128-bit hash value.
Designed for 8-bit computers. Considered cryptographically broken.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_md2 ;
    valuesets:output_bits 128 ;
    valuesets:security_level "broken" .

<http://id.loc.gov/vocabulary/preservation/cryptographicHashFunctions/md5> a owl:Class ;
    rdfs:label "MD5" ;
    dcterms:title "MD5" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """Message Digest 5 algorithm producing a 128-bit hash value.
Widely used but vulnerable to collision attacks. Acceptable
for non-security integrity checks only.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_md5 ;
    valuesets:output_bits 128 ;
    valuesets:security_level "weak" .

<http://id.loc.gov/vocabulary/preservation/cryptographicHashFunctions/sha1> a owl:Class ;
    rdfs:label "SHA_1" ;
    dcterms:title "SHA-1" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:altLabel "SHA1" ;
    skos:definition """Secure Hash Algorithm 1 producing a 160-bit hash value.
Deprecated for security applications due to collision vulnerabilities.
Still acceptable for integrity verification in some contexts.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_sha1 ;
    valuesets:output_bits 160 ;
    valuesets:security_level "weak" .

<http://id.loc.gov/vocabulary/preservation/cryptographicHashFunctions/sha256> a owl:Class ;
    rdfs:label "SHA_256" ;
    dcterms:title "SHA-256" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:altLabel "SHA256" ;
    skos:definition """SHA-2 variant producing a 256-bit hash value.
Widely used and considered secure for most applications.
Recommended for digital preservation.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_sha256 ;
    valuesets:output_bits 256 ;
    valuesets:security_level "secure" .

<http://id.loc.gov/vocabulary/preservation/cryptographicHashFunctions/sha384> a owl:Class ;
    rdfs:label "SHA_384" ;
    dcterms:title "SHA-384" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:altLabel "SHA384" ;
    skos:definition """SHA-2 variant producing a 384-bit hash value.
Truncated version of SHA-512.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_sha384 ;
    valuesets:output_bits 384 ;
    valuesets:security_level "secure" .

<http://id.loc.gov/vocabulary/preservation/cryptographicHashFunctions/sha512> a owl:Class ;
    rdfs:label "SHA_512" ;
    dcterms:title "SHA-512" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:altLabel "SHA512" ;
    skos:definition """SHA-2 variant producing a 512-bit hash value.
Highest security level in the SHA-2 family.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_sha512 ;
    valuesets:output_bits 512 ;
    valuesets:security_level "secure" .

<http://id.loc.gov/vocabulary/preservation/cryptographicHashFunctions/tig> a owl:Class ;
    rdfs:label "TIGER" ;
    dcterms:title "Tiger" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """A cryptographic hash function designed for 64-bit platforms.
Produces a 192-bit hash value.
""" ;
    valuesets:output_bits 192 ;
    valuesets:security_level "adequate" .

<http://id.loc.gov/vocabulary/preservation/cryptographicHashFunctions/unk> a owl:Class ;
    rdfs:label "UNKNOWN" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition "The hash algorithm is not known or not specified." .

<http://id.loc.gov/vocabulary/preservation/cryptographicHashFunctions/whi> a owl:Class ;
    rdfs:label "WHIRLPOOL" ;
    dcterms:title "Whirlpool" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """A cryptographic hash function producing a 512-bit hash value.
Based on a modified AES block cipher.
""" ;
    valuesets:output_bits 512 ;
    valuesets:security_level "secure" .

<http://id.loc.gov/vocabulary/preservation/eventOutcome/fai> a owl:Class ;
    rdfs:label "FAILURE" ;
    rdfs:subClassOf valuesets:PreservationEventOutcome ;
    skos:definition "The event failed to complete." .

<http://id.loc.gov/vocabulary/preservation/eventOutcome/suc> a owl:Class ;
    rdfs:label "SUCCESS" ;
    rdfs:subClassOf valuesets:PreservationEventOutcome ;
    skos:definition "The event completed successfully." .

<http://id.loc.gov/vocabulary/preservation/eventOutcome/war> a owl:Class ;
    rdfs:label "WARNING" ;
    rdfs:subClassOf valuesets:PreservationEventOutcome ;
    skos:definition "The event completed with warnings or issues." .

<http://id.loc.gov/vocabulary/preservation/eventType/acc> a owl:Class ;
    rdfs:label "ACCESSION" ;
    rdfs:subClassOf valuesets:PreservationEventType ;
    skos:definition "The process of adding objects to a repository's holdings." .

<http://id.loc.gov/vocabulary/preservation/eventType/app> a owl:Class ;
    rdfs:label "APPRAISAL" ;
    rdfs:subClassOf valuesets:PreservationEventType ;
    skos:definition "The process of evaluating objects for long-term retention." .

<http://id.loc.gov/vocabulary/preservation/eventType/cap> a owl:Class ;
    rdfs:label "CAPTURE" ;
    rdfs:subClassOf valuesets:PreservationEventType ;
    skos:definition "The process of recording or acquiring digital content." .

<http://id.loc.gov/vocabulary/preservation/eventType/cmp> a owl:Class ;
    rdfs:label "COMPRESSION" ;
    rdfs:subClassOf valuesets:PreservationEventType ;
    skos:definition "The process of reducing file size through encoding." .

<http://id.loc.gov/vocabulary/preservation/eventType/com> a owl:Class ;
    rdfs:label "COMPILING" ;
    rdfs:subClassOf valuesets:PreservationEventType ;
    skos:definition "The process of converting source code into executable code." .

<http://id.loc.gov/vocabulary/preservation/eventType/cre> a owl:Class ;
    rdfs:label "CREATION" ;
    rdfs:subClassOf valuesets:PreservationEventType ;
    skos:definition "The act of creating a new digital object." .

<http://id.loc.gov/vocabulary/preservation/eventType/dea> a owl:Class ;
    rdfs:label "DEACCESSION" ;
    rdfs:subClassOf valuesets:PreservationEventType ;
    skos:definition "The process of removing objects from a repository's holdings." .

<http://id.loc.gov/vocabulary/preservation/eventType/dec> a owl:Class ;
    rdfs:label "DECOMPRESSION" ;
    rdfs:subClassOf valuesets:PreservationEventType ;
    skos:definition "The process of restoring compressed data to its original form." .

<http://id.loc.gov/vocabulary/preservation/eventType/del> a owl:Class ;
    rdfs:label "DELETION" ;
    rdfs:subClassOf valuesets:PreservationEventType ;
    skos:definition "The act of removing a digital object." .

<http://id.loc.gov/vocabulary/preservation/eventType/der> a owl:Class ;
    rdfs:label "DECRYPTION" ;
    rdfs:subClassOf valuesets:PreservationEventType ;
    skos:definition "The process of converting encrypted data back to plaintext." .

<http://id.loc.gov/vocabulary/preservation/eventType/dig> a owl:Class ;
    rdfs:label "DIGITAL_SIGNATURE_GENERATION" ;
    dcterms:title "Digital Signature Generation" ;
    rdfs:subClassOf valuesets:PreservationEventType ;
    skos:definition "The process of creating a digital signature for authentication." .

<http://id.loc.gov/vocabulary/preservation/eventType/dip> a owl:Class ;
    rdfs:label "DISPLAYING" ;
    rdfs:subClassOf valuesets:PreservationEventType ;
    skos:definition "The process of presenting content for viewing." .

