    valuesets:measurements "porosity, permeability, saturation, mechanical strength" .

<https://w3id.org/valuesets/ReservoirCharacterizationMethodType#GEOSTATISTICAL_MODELING> a owl:Class ;
    rdfs:label "GEOSTATISTICAL_MODELING" ;
    rdfs:subClassOf valuesets:ReservoirCharacterizationMethodType ;
    skos:definition "Statistical methods for spatial interpolation and uncertainty quantification of reservoir properties" ;
    valuesets:methods "kriging, sequential Gaussian simulation, multiple-point statistics" .

<https://w3id.org/valuesets/ReservoirCharacterizationMethodType#PRESSURE_TRANSIENT_ANALYSIS> a owl:Class ;
    rdfs:label "PRESSURE_TRANSIENT_ANALYSIS" ;
    rdfs:subClassOf valuesets:ReservoirCharacterizationMethodType ;
    skos:definition "Analysis of pressure changes over time during well operations to infer reservoir characteristics" ;
    valuesets:tests "drawdown, buildup, interference" .

<https://w3id.org/valuesets/ReservoirCharacterizationMethodType#PRODUCTION_HISTORY_MATCHING> a owl:Class ;
    rdfs:label "PRODUCTION_HISTORY_MATCHING" ;
    rdfs:subClassOf valuesets:ReservoirCharacterizationMethodType ;
    skos:definition "Calibration of reservoir simulation models by matching historical production data" ;
    valuesets:approach "inverse modeling, parameter estimation" .

