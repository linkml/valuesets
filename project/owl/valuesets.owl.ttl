<https://w3id.org/valuesets/HealthcareEncounterClassification#Ambulance%20Visit> a owl:Class ;
    rdfs:label "Ambulance Visit" ;
    rdfs:subClassOf valuesets:HealthcareEncounterClassification ;
    skos:definition "Person using transportation service for the purpose of initiating one of the other Visits, without a Care Site, within one day, potentially with Providers accompanying the Visit and delivering service" .

<https://w3id.org/valuesets/HealthcareEncounterClassification#Case%20Management%20Visit> a owl:Class ;
    rdfs:label "Case Management Visit" ;
    rdfs:subClassOf valuesets:HealthcareEncounterClassification ;
    skos:definition "Person interacting with healthcare system, without a Care Site, within a day, with no Providers involved, for administrative purposes" .

<https://w3id.org/valuesets/HealthcareEncounterClassification#Emergency%20Room%20Visit> a owl:Class ;
    rdfs:label "Emergency Room Visit" ;
    rdfs:subClassOf valuesets:HealthcareEncounterClassification ;
    skos:definition "Person visiting dedicated healthcare institution for treating emergencies, at a Care Site, within one day, with physicians and Providers permanently available to deliver service around the clock" .

<https://w3id.org/valuesets/HealthcareEncounterClassification#Emergency%20Room%20and%20Inpatient%20Visit> a owl:Class ;
    rdfs:label "Emergency Room and Inpatient Visit" ;
    rdfs:subClassOf valuesets:HealthcareEncounterClassification ;
    skos:definition "Person visiting ER followed by a subsequent Inpatient Visit, where Emergency department is part of hospital, and transition from the ER to other hospital departments is undefined" .

<https://w3id.org/valuesets/HealthcareEncounterClassification#Home%20Visit> a owl:Class ;
    rdfs:label "Home Visit" ;
    rdfs:subClassOf valuesets:HealthcareEncounterClassification ;
    skos:definition "Provider visiting Person, without a Care Site, within one day, delivering service" .

<https://w3id.org/valuesets/HealthcareEncounterClassification#Inpatient%20Visit> a owl:Class ;
    rdfs:label "Inpatient Visit" ;
    rdfs:subClassOf valuesets:HealthcareEncounterClassification ;
    skos:definition "Person visiting hospital, at a Care Site, in bed, for duration of more than one day, with physicians and other Providers permanently available to deliver service around the clock" .

<https://w3id.org/valuesets/HealthcareEncounterClassification#Laboratory%20Visit> a owl:Class ;
    rdfs:label "Laboratory Visit" ;
    rdfs:subClassOf valuesets:HealthcareEncounterClassification ;
    skos:definition "Patient visiting dedicated institution, at a Care Site, within one day, for the purpose of a Measurement." .

<https://w3id.org/valuesets/HealthcareEncounterClassification#Non-hospital%20institution%20Visit> a owl:Class ;
    rdfs:label "Non-hospital institution Visit" ;
    rdfs:subClassOf valuesets:HealthcareEncounterClassification ;
    skos:definition "Person visiting dedicated institution for reasons of poor health, at a Care Site, long-term or permanently, with no physician but possibly other Providers permanently available to deliver service around the clock" .

<https://w3id.org/valuesets/HealthcareEncounterClassification#Outpatient%20Visit> a owl:Class ;
    rdfs:label "Outpatient Visit" ;
    rdfs:subClassOf valuesets:HealthcareEncounterClassification ;
    skos:definition "Person visiting dedicated ambulatory healthcare institution, at a Care Site, within one day, without bed, with physicians or medical Providers delivering service during Visit" .

<https://w3id.org/valuesets/HealthcareEncounterClassification#Pharmacy%20Visit> a owl:Class ;
    rdfs:label "Pharmacy Visit" ;
    rdfs:subClassOf valuesets:HealthcareEncounterClassification ;
    skos:definition "Person visiting pharmacy for dispensing of Drug, at a Care Site, within one day" .

<https://w3id.org/valuesets/HealthcareEncounterClassification#Telehealth%20Visit> a owl:Class ;
    rdfs:label "Telehealth Visit" ;
    rdfs:subClassOf valuesets:HealthcareEncounterClassification ;
    skos:definition "Patient engages with Provider through communication media" .

