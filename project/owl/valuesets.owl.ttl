    valuesets:temperature_min_c 150 .

<https://w3id.org/valuesets/GeothermalResourceTemperature#LOW_TEMPERATURE> a owl:Class ;
    rdfs:label "LOW_TEMPERATURE" ;
    dcterms:title "Low Temperature Resource" ;
    rdfs:subClassOf valuesets:GeothermalResourceTemperature ;
