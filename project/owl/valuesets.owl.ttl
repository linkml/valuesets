<https://w3id.org/valuesets/GeothermalReservoirType#VOLCANIC> a owl:Class ;
    rdfs:label "VOLCANIC" ;
    dcterms:title "Volcanic Reservoir" ;
    rdfs:subClassOf valuesets:GeothermalReservoirType ;
    skos:broadMatch <http://sweetontology.net/realmLandVolcanic/VolcanicField> ;
