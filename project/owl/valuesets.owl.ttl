    rdfs:label "SURROUNDS" ;
    dcterms:title "Encircles or encompasses" ;
    rdfs:subClassOf valuesets:SpatialRelationship ;
    skos:altLabel "surrounds" .

RO:0002227 a owl:Class ;
    rdfs:label "OBLIGATE_PARASITE_OF" ;
    rdfs:subClassOf RO:0002444,
        valuesets:BioticInteractionType ;
    skos:definition """A sub-relation of parasite-of in which the parasite that cannot complete its life cycle without a host.
""" .

RO:0002228 a owl:Class ;
    rdfs:label "FACULTATIVE_PARASITE_OF" ;
    rdfs:subClassOf RO:0002444,
        valuesets:BioticInteractionType ;
    skos:definition """A sub-relations of parasite-of in which the parasite that can complete its life cycle independent of a host.
""" .

RO:0002235 a owl:Class ;
    rdfs:label "STEM_PARASITE_OF" ;
    rdfs:subClassOf RO:0002444,
        valuesets:BioticInteractionType ;
    skos:definition """A parasite-of relationship in which the host is a plant and the parasite that attaches to the host stem.
""" .

RO:0002236 a owl:Class ;
    rdfs:label "ROOT_PARASITE_OF" ;
    rdfs:subClassOf RO:0002444,
        valuesets:BioticInteractionType ;
    skos:definition """A parasite-of relationship in which the host is a plant and the parasite that attaches to the host root.
""" .

RO:0002237 a owl:Class ;
    rdfs:label "HEMIPARASITE_OF" ;
    rdfs:subClassOf RO:0002444,
        valuesets:BioticInteractionType ;
    skos:definition """A sub-relation of parasite-of in which the parasite is a plant, and the parasite is parasitic under natural conditions and is also photosynthetic to some degree.
""" .

RO:0002304 a owl:Class ;
    rdfs:label "CAUSALLY_UPSTREAM_OF_POSITIVE_EFFECT" ;
    dcterms:title "causally upstream of, positive effect" ;
    rdfs:subClassOf RO:0002411,
        valuesets:CausalPredicateEnum ;
    valuesets:direction "POSITIVE" ;
    valuesets:symbol "+" .

RO:0002305 a owl:Class ;
    rdfs:label "CAUSALLY_UPSTREAM_OF_NEGATIVE_EFFECT" ;
    dcterms:title "causally upstream of, negative effect" ;
    rdfs:subClassOf RO:0002411,
        valuesets:CausalPredicateEnum ;
    valuesets:direction "NEGATIVE" ;
    valuesets:symbol "-" .

RO:0002407 a owl:Class ;
    rdfs:label "INDIRECTLY_POSITIVELY_REGULATES" ;
    dcterms:title "indirectly positively regulates" ;
    rdfs:subClassOf RO:0002213,
        valuesets:CausalPredicateEnum ;
    valuesets:direction "POSITIVE" ;
    valuesets:directness "INDIRECT" .

RO:0002409 a owl:Class ;
    rdfs:label "INDIRECTLY_NEGATIVELY_REGULATES" ;
    dcterms:title "indirectly negatively regulates" ;
    rdfs:subClassOf RO:0002212,
        valuesets:CausalPredicateEnum ;
    valuesets:direction "NEGATIVE" ;
    valuesets:directness "INDIRECT" .

RO:0002413 a owl:Class ;
    rdfs:label "PROVIDES_INPUT_FOR" ;
    dcterms:title "provides input for" ;
    rdfs:subClassOf valuesets:CausalPredicateEnum .

RO:0002439 a owl:Class ;
    rdfs:label "PREYS_ON" ;
    rdfs:subClassOf RO:0002438,
        valuesets:BioticInteractionType ;
    skos:definition """An interaction relationship involving a predation process, where the subject kills the target in order to eat it or to feed to siblings, offspring or group members.
""" .

RO:0002441 a owl:Class ;
    rdfs:label "COMMENSUALLY_INTERACTS_WITH" ;
    rdfs:subClassOf RO:0002440,
        valuesets:BioticInteractionType ;
    skos:definition """An interaction relationship between two organisms living together in more or less intimate association in a relationship in which one benefits and the other is unaffected.
""" .

RO:0002442 a owl:Class ;
    rdfs:label "MUTUALISTICALLY_INTERACTS_WITH" ;
    rdfs:subClassOf RO:0002440,
        valuesets:BioticInteractionType ;
    skos:definition """An interaction relationship between two organisms living together in more or less intimate association in a relationship in which both organisms benefit from each other.
""" .

RO:0002446 a owl:Class ;
    rdfs:label "PARTICIPATES_IN_ABIOTIC_BIOTIC_INTERACTION_WITH" ;
    dcterms:title "participates in a abiotic-biotic interaction with" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition """A biotic interaction relationship in which one partner is an organism and the other partner is inorganic. For example, the relationship between a sponge and the substrate to which is it anchored.
""" .

RO:0002455 a owl:Class ;
    rdfs:label "POLLINATES" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition "An interaction where an organism transfers pollen to a plant" .

RO:0002457 a owl:Class ;
    rdfs:label "ACQUIRES_NUTRIENTS_FROM" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition "Inverse of provides nutrients for" .

RO:0002458 a owl:Class ;
    rdfs:label "PREYED_UPON_BY" ;
    rdfs:subClassOf RO:0002438,
        valuesets:BioticInteractionType ;
    skos:definition "Inverse of preys on" .

RO:0002459 a owl:Class ;
    rdfs:label "IS_VECTOR_FOR" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition "Organism acts as a vector for transmitting another organism" .

RO:0002469 a owl:Class ;
    rdfs:label "PROVIDES_NUTRIENTS_FOR" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition "A biotic interaction where a material entity provides nutrition for an organism." .

RO:0002470 a owl:Class ;
    rdfs:label "EATS" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition """A biotic interaction where one organism consumes a material entity through a type of mouth or other oral opening.
""" .

RO:0002471 a owl:Class ;
    rdfs:label "IS_EATEN_BY" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition "Inverse of eats" .

RO:0002553 a owl:Class ;
    rdfs:label "HYPERPARASITE_OF" ;
    rdfs:subClassOf RO:0002444,
        valuesets:BioticInteractionType ;
    skos:definition "x is a hyperparasite of y iff x is a parasite of a parasite of the target organism y" .

RO:0002555 a owl:Class ;
    rdfs:label "ALLELOPATH_OF" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition """A relationship between organisms where one organism is influenced by the biochemicals produced by another. Allelopathy is a phenomenon in which one organism releases chemicals to positively or negatively influence the growth, survival or reproduction of other organisms in its vicinity.
""" .

RO:0002556 a owl:Class ;
    rdfs:label "PATHOGEN_OF" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition "Inverse of has pathogen" .

RO:0002557 a owl:Class ;
    rdfs:label "HAS_PATHOGEN" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition """A host interaction where the smaller of the two members of a symbiosis causes a disease in the larger member.
""" .

RO:0002622 a owl:Class ;
    rdfs:label "VISITS_FLOWERS_OF" ;
    rdfs:subClassOf RO:0002618,
        valuesets:BioticInteractionType ;
    skos:definition "An interaction where an organism visits the flowers of a plant" .

RO:0002623 a owl:Class ;
    rdfs:label "HAS_FLOWERS_VISITED_BY" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition "Inverse of visits flowers of" .

RO:0002624 a owl:Class ;
    rdfs:label "LAYS_EGGS_IN" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition "An interaction where an organism deposits eggs inside another organism" .

RO:0002625 a owl:Class ;
    rdfs:label "HAS_EGGS_LAID_IN_BY" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition "Inverse of lays eggs in" .

RO:0002629 a owl:Class ;
    rdfs:label "DIRECTLY_POSITIVELY_REGULATES" ;
    dcterms:title "directly positively regulates" ;
    rdfs:subClassOf RO:0002213,
        valuesets:CausalPredicateEnum ;
    valuesets:direction "POSITIVE" ;
    valuesets:directness "DIRECT" .

RO:0002630 a owl:Class ;
    rdfs:label "DIRECTLY_NEGATIVELY_REGULATES" ;
    dcterms:title "directly negatively regulates" ;
    rdfs:subClassOf RO:0002212,
        valuesets:CausalPredicateEnum ;
    valuesets:direction "NEGATIVE" ;
    valuesets:directness "DIRECT" .

RO:0002632 a owl:Class ;
    rdfs:label "ECTOPARASITE_OF" ;
    rdfs:subClassOf RO:0002444,
        valuesets:BioticInteractionType ;
    skos:definition """A sub-relation of parasite-of in which the parasite lives on or in the integumental system of the host.
""" .

RO:0002636 a owl:Class ;
    rdfs:label "MESOPARASITE_OF" ;
    rdfs:subClassOf RO:0002444,
        valuesets:BioticInteractionType ;
    skos:definition """A sub-relation of parasite-of in which the parasite is partially an endoparasite and partially an ectoparasite.
""" .

RO:0002638 a owl:Class ;
    rdfs:label "INTERCELLULAR_ENDOPARASITE_OF" ;
    rdfs:subClassOf RO:0002634,
        valuesets:BioticInteractionType ;
    skos:definition """A sub-relation of endoparasite-of in which the parasite inhabits the spaces between host cells.
""" .

RO:0002640 a owl:Class ;
    rdfs:label "INTRACELLULAR_ENDOPARASITE_OF" ;
    rdfs:subClassOf RO:0002634,
        valuesets:BioticInteractionType ;
    skos:definition "A sub-relation of endoparasite-of in which the parasite inhabits host cells." .

RO:0002802 a owl:Class ;
    rdfs:label "RESERVOIR_HOST_OF" ;
    rdfs:subClassOf RO:0002453,
        valuesets:BioticInteractionType ;
    skos:definition """A relation between a host organism and a hosted organism in which the hosted organism naturally occurs in an indefinitely maintained reservoir provided by the host.
""" .

RO:0002803 a owl:Class ;
    rdfs:label "HAS_RESERVOIR_HOST" ;
    rdfs:subClassOf RO:0002454,
        valuesets:BioticInteractionType ;
    skos:definition "Inverse of reservoir host of" .

RO:0008501 a owl:Class ;
    rdfs:label "EPIPHYTE_OF" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition """An interaction relationship wherein a plant or algae is living on the outside surface of another plant.
""" .

RO:0008503 a owl:Class ;
    rdfs:label "KLEPTOPARASITE_OF" ;
    rdfs:subClassOf RO:0002444,
        valuesets:BioticInteractionType ;
    skos:definition """A sub-relation of parasite of in which a parasite steals resources from another organism, usually food or nest material.
""" .

RO:0008505 a owl:Class ;
    rdfs:label "CREATES_HABITAT_FOR" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition """An interaction relationship wherein one organism creates a structure or environment that is lived in by another organism.
""" .

RO:0008506 a owl:Class ;
    rdfs:label "ECOLOGICALLY_CO_OCCURS_WITH" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition """An interaction relationship describing organisms that often occur together at the same time and space or in the same environment.
""" .

RO:0008507 a owl:Class ;
    rdfs:label "LAYS_EGGS_ON" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition """An interaction relationship in which organism a lays eggs on the outside surface of organism b. Organism b is neither helped nor harmed in the process of egg laying or incubation.
""" .

RO:0008508 a owl:Class ;
    rdfs:label "HAS_EGGS_LAID_ON_BY" ;
    rdfs:subClassOf RO:0002437,
        valuesets:BioticInteractionType ;
    skos:definition "Inverse of lays eggs on" .

RO:0008510 a owl:Class ;
    rdfs:label "SYMBIOTROPHICALLY_INTERACTS_WITH" ;
    rdfs:subClassOf RO:0002440,
        valuesets:BioticInteractionType ;
    skos:definition """A trophic interaction in which one organism acquires nutrients through a symbiotic relationship with another organism.
""" .

RO:0008511 a owl:Class ;
    rdfs:label "TROPHIC_PARASITE_OF" ;
    rdfs:subClassOf RO:0002444,
        valuesets:BioticInteractionType ;
    skos:definition """A symbiotrophic interaction in which one organism acquires nutrients through a parasitic relationship with another organism.
""" .

