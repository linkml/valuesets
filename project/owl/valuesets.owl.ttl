<https://w3id.org/valuesets/HydrogeologyWellType#OBSERVATION_WELL> a owl:Class ;
    rdfs:label "OBSERVATION_WELL" ;
    rdfs:subClassOf valuesets:HydrogeologyWellType ;
    skos:definition "A well used to observe hydrological parameters without significant water extraction" .

<https://w3id.org/valuesets/HydrogeologyWellType#PIEZOMETER> a owl:Class ;
    rdfs:label "PIEZOMETER" ;
    rdfs:subClassOf valuesets:HydrogeologyWellType ;
    skos:definition "A device or small-diameter well used to measure hydraulic head at a specific point in the subsurface" .

<https://w3id.org/valuesets/HydrogeologyWellType#PRODUCTION_WELL> a owl:Class ;
    rdfs:label "PRODUCTION_WELL" ;
    rdfs:subClassOf valuesets:HydrogeologyWellType ;
