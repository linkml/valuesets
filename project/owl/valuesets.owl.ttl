""" .

<https://w3id.org/valuesets/PreservationLevelValue#FULL_PRESERVATION> a owl:Class ;
    rdfs:label "FULL_PRESERVATION" ;
    dcterms:title "Full Preservation" ;
    rdfs:subClassOf valuesets:PreservationLevelValue ;
    skos:altLabel "Level 4" ;
    skos:definition """Comprehensive preservation including all aspects: bit-level integrity,
format migration, semantic context, and provenance tracking.
""" .

<https://w3id.org/valuesets/PreservationLevelValue#LOGICAL_PRESERVATION> a owl:Class ;
    rdfs:label "LOGICAL_PRESERVATION" ;
    dcterms:title "Logical Preservation" ;
    rdfs:subClassOf valuesets:PreservationLevelValue ;
    skos:altLabel "Content Preservation",
        "Level 2" ;
    skos:definition """Maintains the ability to render or use the content. May include
format migration to ensure long-term accessibility.
""" .

<https://w3id.org/valuesets/PreservationLevelValue#SEMANTIC_PRESERVATION> a owl:Class ;
    rdfs:label "SEMANTIC_PRESERVATION" ;
    dcterms:title "Semantic Preservation" ;
    rdfs:subClassOf valuesets:PreservationLevelValue ;
    skos:altLabel "Full Preservation",
        "Level 3" ;
    skos:definition """Preserves the meaning and context of content, including relationships
