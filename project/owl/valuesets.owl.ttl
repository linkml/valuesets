<https://w3id.org/valuesets/GeothermalSystemType#SUPERCRITICAL> a owl:Class ;
    rdfs:label "SUPERCRITICAL" ;
    dcterms:title "Supercritical Geothermal System" ;
    rdfs:subClassOf valuesets:GeothermalSystemType ;
