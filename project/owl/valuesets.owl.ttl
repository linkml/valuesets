HP:0000006 a owl:Class ;
    rdfs:label "AUTOSOMAL_DOMINANT" ;
    dcterms:title "Autosomal dominant inheritance" ;
    rdfs:subClassOf valuesets:ModeOfInheritance ;
    skos:definition "A mode of inheritance that is observed for traits related to a gene encoded on one of the autosomes in which a trait manifests in heterozygotes." .

HP:0000007 a owl:Class ;
    rdfs:label "AUTOSOMAL_RECESSIVE" ;
    dcterms:title "Autosomal recessive inheritance" ;
    rdfs:subClassOf valuesets:ModeOfInheritance ;
    skos:definition "A mode of inheritance that is observed for traits related to a gene encoded on one of the autosomes in which a trait manifests in individuals with two pathogenic alleles." .

HP:0000635 a owl:Class ;
    rdfs:label "BLUE" ;
    dcterms:title "Blue irides" ;
    rdfs:subClassOf valuesets:EyeColorEnum ;
    skos:definition "Blue eyes" ;
    valuesets:hex_range "4169E1-87CEEB" ;
    valuesets:prevalence "8-10% worldwide" .

HP:0001100 a owl:Class ;
    rdfs:label "HETEROCHROMIA" ;
    dcterms:title "Heterochromia iridis" ;
    rdfs:subClassOf valuesets:EyeColorEnum ;
    skos:definition "Different colored eyes" ;
    valuesets:note "complete or sectoral heterochromia" .

HP:0001419 a owl:Class ;
    rdfs:label "X_LINKED_RECESSIVE" ;
    dcterms:title "X-linked recessive inheritance" ;
    rdfs:subClassOf HP:0001417,
        valuesets:ModeOfInheritance ;
    skos:definition "A mode of inheritance that is observed for recessive traits related to a gene encoded on the X chromosome." .

HP:0001423 a owl:Class ;
    rdfs:label "X_LINKED_DOMINANT" ;
    dcterms:title "X-linked dominant inheritance" ;
    rdfs:subClassOf HP:0001417,
        valuesets:ModeOfInheritance ;
    skos:definition "A mode of inheritance that is observed for dominant traits related to a gene encoded on the X chromosome." .

HP:0001427 a owl:Class ;
    rdfs:label "MITOCHONDRIAL" ;
    dcterms:title "Mitochondrial inheritance" ;
    rdfs:subClassOf valuesets:ModeOfInheritance ;
    skos:definition "A mode of inheritance that is observed for traits related to a gene encoded on the mitochondrial genome. Maternally inherited." .

HP:0001450 a owl:Class ;
    rdfs:label "Y_LINKED" ;
    dcterms:title "Y-linked inheritance" ;
    rdfs:subClassOf valuesets:ModeOfInheritance ;
    skos:definition "A mode of inheritance that is observed for traits related to a gene encoded on the Y chromosome." .

