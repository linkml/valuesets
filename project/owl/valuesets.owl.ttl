<https://cdisc.org> a owl:Class ;
    rdfs:label "CDISC" ;
    dcterms:title "CDISC" ;
    rdfs:subClassOf valuesets:ValueSetStewardEnum ;
    skos:altLabel "Clinical Data Interchange Standards Consortium" ;
    skos:definition """Clinical Data Interchange Standards Consortium. Develops global
data standards for clinical research including CDASH, SDTM,
and ADaM.
""" ;
    valuesets:established "1997" ;
    valuesets:website "https://cdisc.org" .

CRediT:conceptualization a owl:Class ;
    rdfs:label "CONCEPTUALIZATION" ;
    rdfs:subClassOf valuesets:ResearchRole ;
    skos:definition "Ideas; formulation of research goals" .

CRediT:methodology a owl:Class ;
    rdfs:label "METHODOLOGY" ;
    rdfs:subClassOf valuesets:ResearchRole ;
    skos:definition "Development of methodology" .

CRediT:resources a owl:Class ;
    rdfs:label "RESOURCES" ;
    rdfs:subClassOf valuesets:ResearchRole ;
    skos:definition "Provision of materials and tools" .

CRediT:software a owl:Class ;
    rdfs:label "SOFTWARE" ;
    rdfs:subClassOf valuesets:ResearchRole ;
    skos:definition "Programming and software development" .

CRediT:validation a owl:Class ;
    rdfs:label "VALIDATION" ;
    rdfs:subClassOf valuesets:ResearchRole ;
    skos:definition "Verification of results" .

CRediT:visualization a owl:Class ;
    rdfs:label "VISUALIZATION" ;
    rdfs:subClassOf valuesets:ResearchRole ;
    skos:definition "Data presentation and visualization" .

CRediT:writing-original-draft a owl:Class ;
    rdfs:label "WRITING_ORIGINAL" ;
    rdfs:subClassOf valuesets:ResearchRole ;
    skos:definition "Writing - original draft" .

DataCite:Audiovisual a owl:Class ;
    rdfs:label "AUDIOVISUAL" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A series of visual representations imparting an impression of motion
when shown in succession. May include sound.
""" ;
    skos:exactMatch DCMITYPE:MovingImage ;
    valuesets:examples "video, film, animation" .

DataCite:Award a owl:Class ;
    rdfs:label "AWARD" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """Funding or support provided to an individual or organization
for research, academic work, or professional development.
""" ;
    valuesets:added_version "4.6" ;
    valuesets:examples "grant award, fellowship, scholarship" .

DataCite:Book a owl:Class ;
    rdfs:label "BOOK" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A medium for recording information in the form of writing or images,
typically composed of many pages bound together.
""" ;
    skos:exactMatch DCMITYPE:Text,
        FABIO:Book .

DataCite:BookChapter a owl:Class ;
    rdfs:label "BOOK_CHAPTER" ;
    dcterms:title "Book Chapter" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition "One of the main divisions of a book." ;
    skos:exactMatch FABIO:BookChapter .

DataCite:Cites a owl:Class ;
    rdfs:label "CITES" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A includes B in a citation." ;
    skos:exactMatch dcterms:references,
        cito:cites ;
    valuesets:category "citation" ;
    valuesets:inverse "IS_CITED_BY" .

DataCite:Collection a owl:Class ;
    rdfs:label "COLLECTION" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """An aggregation of resources, which may encompass collections of
one resource type as well as those of mixed types.
""" ;
    skos:exactMatch DCMITYPE:Collection .

DataCite:Collects a owl:Class ;
    rdfs:label "COLLECTS" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A collects B." ;
    valuesets:category "collection" ;
    valuesets:inverse "IS_COLLECTED_BY" .

DataCite:Compiles a owl:Class ;
    rdfs:label "COMPILES" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that B is the result of a compile or creation event using A." ;
    valuesets:category "derivation" ;
    valuesets:inverse "IS_COMPILED_BY" .

DataCite:ComputationalNotebook a owl:Class ;
    rdfs:label "COMPUTATIONAL_NOTEBOOK" ;
    dcterms:title "Computational Notebook" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A virtual notebook environment used for literate programming,
combining code, documentation, and visualizations.
""" ;
    valuesets:examples "Jupyter notebook, R Markdown, Observable" .

DataCite:ConferencePaper a owl:Class ;
    rdfs:label "CONFERENCE_PAPER" ;
    dcterms:title "Conference Paper" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """Article written with the goal of being accepted to a conference.
""" ;
    skos:exactMatch FABIO:ConferencePaper .

DataCite:ConferenceProceeding a owl:Class ;
    rdfs:label "CONFERENCE_PROCEEDING" ;
    dcterms:title "Conference Proceeding" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """Collection of academic papers published in the context of
an academic conference.
""" ;
    skos:exactMatch FABIO:ConferenceProceedings .

DataCite:ContactPerson a owl:Class ;
    rdfs:label "CONTACT_PERSON" ;
    dcterms:title "Contact Person" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:definition """Person with knowledge of how to access, troubleshoot, or
otherwise field issues related to the resource.
""" ;
    valuesets:category "support" .

DataCite:Continues a owl:Class ;
    rdfs:label "CONTINUES" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is a continuation of the work B." ;
    valuesets:category "continuation" ;
    valuesets:inverse "IS_CONTINUED_BY" .

DataCite:DataCollector a owl:Class ;
    rdfs:label "DATA_COLLECTOR" ;
    dcterms:title "Data Collector" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:closeMatch CRediT:investigation ;
    skos:definition """Person or institution responsible for finding, gathering, or
collecting data under the guidelines of the author(s) or
Principal Investigator (PI).
""" ;
    valuesets:category "data_work" .

DataCite:DataCurator a owl:Class ;
    rdfs:label "DATA_CURATOR" ;
    dcterms:title "Data Curator" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:closeMatch CRediT:data-curation ;
    skos:definition """Person tasked with reviewing, enhancing, cleaning, or standardizing
metadata and the associated data submitted for storage, use, and
maintenance within a repository.
""" ;
    valuesets:category "data_work" .

DataCite:DataManager a owl:Class ;
    rdfs:label "DATA_MANAGER" ;
    dcterms:title "Data Manager" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:closeMatch CRediT:data-curation ;
    skos:definition """Person or organization responsible for maintaining the finished
resource, including data quality, access permissions, and
long-term availability.
""" ;
    valuesets:category "data_work" .

DataCite:DataPaper a owl:Class ;
    rdfs:label "DATA_PAPER" ;
    dcterms:title "Data Paper" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A scholarly publication describing a dataset, intended to
facilitate its discovery, interpretation, and reuse.
""" ;
    skos:exactMatch FABIO:DataPaper .

DataCite:Dataset a owl:Class ;
    rdfs:label "DATASET" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """Data encoded in a defined structure. May include tables,
databases, or other structured data.
""" ;
    skos:exactMatch DCMITYPE:Dataset .

DataCite:Describes a owl:Class ;
    rdfs:label "DESCRIBES" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A describes B." ;
    valuesets:category "description" ;
    valuesets:inverse "IS_DESCRIBED_BY" .

DataCite:Dissertation a owl:Class ;
    rdfs:label "DISSERTATION" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A written essay, treatise, or thesis, especially one written
by a candidate for a doctoral degree.
""" ;
    skos:exactMatch FABIO:DoctoralThesis .

DataCite:Distributor a owl:Class ;
    rdfs:label "DISTRIBUTOR" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:definition """Institution tasked with responsibility to generate or disseminate
copies of the resource in either electronic or print form.
""" ;
    skos:exactMatch marcrel:dst ;
    valuesets:category "dissemination" .

DataCite:Documents a owl:Class ;
    rdfs:label "DOCUMENTS" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is documentation about/explaining B." ;
    valuesets:category "documentation" ;
    valuesets:inverse "IS_DOCUMENTED_BY" .

DataCite:Editor a owl:Class ;
    rdfs:label "EDITOR" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:closeMatch CRediT:writing-review-editing ;
    skos:definition """A person who oversees the details related to the publication
format of the resource.
""" ;
    skos:exactMatch marcrel:edt ;
    valuesets:category "editorial" .

DataCite:Event a owl:Class ;
    rdfs:label "EVENT" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A non-persistent, time-based occurrence. May be planned or
unplanned.
""" ;
    skos:exactMatch DCMITYPE:Event ;
    valuesets:examples "conference, workshop, exhibition" .

DataCite:HasMetadata a owl:Class ;
    rdfs:label "HAS_METADATA" ;
    dcterms:title "Has Metadata" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that resource A has additional metadata B." ;
    valuesets:category "metadata" ;
    valuesets:inverse "IS_METADATA_FOR" .

DataCite:HasPart a owl:Class ;
    rdfs:label "HAS_PART" ;
    dcterms:title "Has Part" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A includes the part B." ;
    skos:exactMatch dcterms:hasPart ;
    valuesets:category "partonomy" ;
    valuesets:inverse "IS_PART_OF" .

DataCite:HasTranslation a owl:Class ;
    rdfs:label "HAS_TRANSLATION" ;
    dcterms:title "Has Translation" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A has a translation B." ;
    valuesets:added_version "4.6" ;
    valuesets:category "translation" ;
    valuesets:inverse "IS_TRANSLATION_OF" .

DataCite:HasVersion a owl:Class ;
    rdfs:label "HAS_VERSION" ;
    dcterms:title "Has Version" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A has a version B." ;
    valuesets:category "versioning" ;
    valuesets:inverse "IS_VERSION_OF" .

DataCite:HostingInstitution a owl:Class ;
    rdfs:label "HOSTING_INSTITUTION" ;
    dcterms:title "Hosting Institution" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:definition """Typically, the organization allowing the resource to be available
on the internet through the provision of its hardware, software,
or operating support.
""" ;
    valuesets:category "infrastructure" .

DataCite:Image a owl:Class ;
    rdfs:label "IMAGE" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A visual representation other than text, including photographs,
diagrams, illustrations, and other static visual works.
""" ;
    skos:exactMatch DCMITYPE:Image,
        DCMITYPE:StillImage .

DataCite:Instrument a owl:Class ;
    rdfs:label "INSTRUMENT" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A device, tool, or apparatus used to obtain, measure, and/or
analyze data.
""" ;
    valuesets:examples "microscope, telescope, sensor, spectrometer" .

DataCite:InteractiveResource a owl:Class ;
    rdfs:label "INTERACTIVE_RESOURCE" ;
    dcterms:title "Interactive Resource" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A resource requiring interaction from the user to be understood,
executed, or experienced.
""" ;
    skos:exactMatch DCMITYPE:InteractiveResource ;
    valuesets:examples "web application, game, simulation" .

DataCite:IsCitedBy a owl:Class ;
    rdfs:label "IS_CITED_BY" ;
    dcterms:title "Is Cited By" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that B includes A in a citation." ;
    skos:exactMatch cito:isCitedBy ;
    valuesets:category "citation" ;
    valuesets:inverse "CITES" .

DataCite:IsCollectedBy a owl:Class ;
    rdfs:label "IS_COLLECTED_BY" ;
    dcterms:title "Is Collected By" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is collected by B." ;
    valuesets:category "collection" ;
    valuesets:inverse "COLLECTS" .

DataCite:IsCompiledBy a owl:Class ;
    rdfs:label "IS_COMPILED_BY" ;
    dcterms:title "Is Compiled By" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that B is used to compile or create A." ;
    valuesets:category "derivation" ;
    valuesets:inverse "COMPILES" .

DataCite:IsContinuedBy a owl:Class ;
    rdfs:label "IS_CONTINUED_BY" ;
    dcterms:title "Is Continued By" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is continued by the work B." ;
    valuesets:category "continuation" ;
    valuesets:inverse "CONTINUES" .

DataCite:IsDerivedFrom a owl:Class ;
    rdfs:label "IS_DERIVED_FROM" ;
    dcterms:title "Is Derived From" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that B is a source upon which A is based." ;
    skos:exactMatch prov:wasDerivedFrom ;
    valuesets:category "derivation" ;
    valuesets:inverse "IS_SOURCE_OF" .

DataCite:IsDescribedBy a owl:Class ;
    rdfs:label "IS_DESCRIBED_BY" ;
    dcterms:title "Is Described By" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is described by B." ;
    valuesets:category "description" ;
    valuesets:inverse "DESCRIBES" .

DataCite:IsDocumentedBy a owl:Class ;
    rdfs:label "IS_DOCUMENTED_BY" ;
    dcterms:title "Is Documented By" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that B is documentation about/explaining A." ;
    valuesets:category "documentation" ;
    valuesets:inverse "DOCUMENTS" .

DataCite:IsIdenticalTo a owl:Class ;
    rdfs:label "IS_IDENTICAL_TO" ;
    dcterms:title "Is Identical To" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition """Indicates that A is identical to B, for use when there is a need
to register two separate instances of the same resource.
""" ;
    valuesets:category "identity" .

DataCite:IsMetadataFor a owl:Class ;
    rdfs:label "IS_METADATA_FOR" ;
    dcterms:title "Is Metadata For" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that additional metadata A describes resource B." ;
    valuesets:category "metadata" ;
    valuesets:inverse "HAS_METADATA" .

DataCite:IsNewVersionOf a owl:Class ;
    rdfs:label "IS_NEW_VERSION_OF" ;
    dcterms:title "Is New Version Of" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition """Indicates that A is a new edition of B, where the new edition
has been modified or updated.
""" ;
    valuesets:category "versioning" ;
    valuesets:inverse "IS_PREVIOUS_VERSION_OF" .

DataCite:IsObsoletedBy a owl:Class ;
    rdfs:label "IS_OBSOLETED_BY" ;
    dcterms:title "Is Obsoleted By" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is replaced by B." ;
    skos:exactMatch dcterms:isReplacedBy ;
    valuesets:category "obsolescence" ;
    valuesets:inverse "OBSOLETES" .

DataCite:IsOriginalFormOf a owl:Class ;
    rdfs:label "IS_ORIGINAL_FORM_OF" ;
    dcterms:title "Is Original Form Of" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is the original form of B." ;
    valuesets:category "form" ;
    valuesets:inverse "IS_VARIANT_FORM_OF" .

DataCite:IsPartOf a owl:Class ;
    rdfs:label "IS_PART_OF" ;
    dcterms:title "Is Part Of" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition """Indicates that A is a portion of B. May be used for elements
of a series.
""" ;
    skos:exactMatch dcterms:isPartOf ;
    valuesets:category "partonomy" ;
    valuesets:inverse "HAS_PART" .

DataCite:IsPreviousVersionOf a owl:Class ;
    rdfs:label "IS_PREVIOUS_VERSION_OF" ;
    dcterms:title "Is Previous Version Of" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is a previous edition of B." ;
    valuesets:category "versioning" ;
    valuesets:inverse "IS_NEW_VERSION_OF" .

DataCite:IsPublishedIn a owl:Class ;
    rdfs:label "IS_PUBLISHED_IN" ;
    dcterms:title "Is Published In" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition """Indicates that A is published inside B, but is independent of
other things published inside of B.
""" ;
    valuesets:category "publication" .

DataCite:IsReferencedBy a owl:Class ;
    rdfs:label "IS_REFERENCED_BY" ;
    dcterms:title "Is Referenced By" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is used as a source of information by B." ;
    skos:exactMatch dcterms:isReferencedBy ;
    valuesets:category "reference" ;
    valuesets:inverse "REFERENCES" .

DataCite:IsRequiredBy a owl:Class ;
    rdfs:label "IS_REQUIRED_BY" ;
    dcterms:title "Is Required By" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is required by B." ;
    skos:exactMatch dcterms:isRequiredBy ;
    valuesets:category "dependency" ;
    valuesets:inverse "REQUIRES" .

DataCite:IsReviewedBy a owl:Class ;
    rdfs:label "IS_REVIEWED_BY" ;
    dcterms:title "Is Reviewed By" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is reviewed by B." ;
    skos:exactMatch cito:hasReview ;
    valuesets:category "review" ;
    valuesets:inverse "REVIEWS" .

DataCite:IsSourceOf a owl:Class ;
    rdfs:label "IS_SOURCE_OF" ;
    dcterms:title "Is Source Of" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is a source upon which B is based." ;
    valuesets:category "derivation" ;
    valuesets:inverse "IS_DERIVED_FROM" .

DataCite:IsSupplementTo a owl:Class ;
    rdfs:label "IS_SUPPLEMENT_TO" ;
    dcterms:title "Is Supplement To" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is a supplement to B." ;
    valuesets:category "supplementary" ;
    valuesets:inverse "IS_SUPPLEMENTED_BY" .

DataCite:IsSupplementedBy a owl:Class ;
    rdfs:label "IS_SUPPLEMENTED_BY" ;
    dcterms:title "Is Supplemented By" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that B is a supplement to A." ;
    valuesets:category "supplementary" ;
    valuesets:inverse "IS_SUPPLEMENT_TO" .

DataCite:IsTranslationOf a owl:Class ;
    rdfs:label "IS_TRANSLATION_OF" ;
    dcterms:title "Is Translation Of" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is a translation of B." ;
    valuesets:added_version "4.6" ;
    valuesets:category "translation" ;
    valuesets:inverse "HAS_TRANSLATION" .

DataCite:IsVariantFormOf a owl:Class ;
    rdfs:label "IS_VARIANT_FORM_OF" ;
    dcterms:title "Is Variant Form Of" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is a variant or different form of B." ;
    valuesets:category "form" ;
    valuesets:inverse "IS_ORIGINAL_FORM_OF" .

DataCite:IsVersionOf a owl:Class ;
    rdfs:label "IS_VERSION_OF" ;
    dcterms:title "Is Version Of" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is a version of B." ;
    valuesets:category "versioning" ;
    valuesets:inverse "HAS_VERSION" .

DataCite:Journal a owl:Class ;
    rdfs:label "JOURNAL" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A scholarly publication consisting of articles that is published
regularly throughout the year.
""" ;
    skos:exactMatch FABIO:Journal .

DataCite:JournalArticle a owl:Class ;
    rdfs:label "JOURNAL_ARTICLE" ;
    dcterms:title "Journal Article" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A written composition on a topic of interest, which forms a
separate part of a journal.
""" ;
    skos:exactMatch IAO:0000013,
        FABIO:JournalArticle .

DataCite:Model a owl:Class ;
    rdfs:label "MODEL" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """An abstract, conceptual, graphical, mathematical, or visualization
model that represents empirical objects, phenomena, or processes.
""" ;
    valuesets:examples "3D model, statistical model, simulation model" .

DataCite:Obsoletes a owl:Class ;
    rdfs:label "OBSOLETES" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A replaces B." ;
    skos:exactMatch dcterms:replaces ;
    valuesets:category "obsolescence" ;
    valuesets:inverse "IS_OBSOLETED_BY" .

DataCite:OutputManagementPlan a owl:Class ;
    rdfs:label "OUTPUT_MANAGEMENT_PLAN" ;
    dcterms:title "Output Management Plan" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:altLabel "DMP",
        "Data Management Plan" ;
    skos:definition """A formal document that outlines how research outputs are to be
handled during and after a research project.
""" .

DataCite:PeerReview a owl:Class ;
    rdfs:label "PEER_REVIEW" ;
    dcterms:title "Peer Review" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """Evaluation of scientific, academic, or professional work by
others working in the same field.
""" .

DataCite:PhysicalObject a owl:Class ;
    rdfs:label "PHYSICAL_OBJECT" ;
    dcterms:title "Physical Object" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A physical object or substance, including artifacts, specimens,
samples, and material objects.
""" ;
    skos:exactMatch DCMITYPE:PhysicalObject ;
    valuesets:examples "fossil, artifact, tissue sample, mineral specimen" .

DataCite:Preprint a owl:Class ;
    rdfs:label "PREPRINT" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A version of a scholarly or scientific paper that precedes
formal peer review and publication in a journal.
""" ;
    skos:exactMatch FABIO:Preprint .

DataCite:Producer a owl:Class ;
    rdfs:label "PRODUCER" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:definition """Person or organization responsible for the artistic and technical
aspects of a resource, typically in audiovisual or media contexts.
""" ;
    skos:exactMatch marcrel:pro ;
    valuesets:category "production" .

DataCite:Project a owl:Class ;
    rdfs:label "PROJECT" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A planned endeavor or activity, frequently collaborative,
intended to achieve a particular aim.
""" ;
    valuesets:added_version "4.6" .

DataCite:ProjectLeader a owl:Class ;
    rdfs:label "PROJECT_LEADER" ;
    dcterms:title "Project Leader" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:altLabel "PI",
        "Principal Investigator" ;
    skos:closeMatch CRediT:project-administration ;
    skos:definition """Person officially designated as head of a project team or
sub-project team instrumental in the work necessary to the
development of the resource.
""" ;
    skos:exactMatch NCIt:C19924 ;
    valuesets:category "leadership" .

DataCite:ProjectManager a owl:Class ;
    rdfs:label "PROJECT_MANAGER" ;
    dcterms:title "Project Manager" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:closeMatch CRediT:project-administration ;
    skos:definition """Person officially designated as manager of a project, responsible
for day-to-day management activities.
""" ;
    valuesets:category "leadership" .

DataCite:ProjectMember a owl:Class ;
    rdfs:label "PROJECT_MEMBER" ;
    dcterms:title "Project Member" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:definition """Person on the membership list of a designated project or
project team.
""" ;
    valuesets:category "team" .

DataCite:References a owl:Class ;
    rdfs:label "REFERENCES" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that B is used as a source of information for A." ;
    skos:exactMatch dcterms:references ;
    valuesets:category "reference" ;
    valuesets:inverse "IS_REFERENCED_BY" .

DataCite:RegistrationAgency a owl:Class ;
    rdfs:label "REGISTRATION_AGENCY" ;
    dcterms:title "Registration Agency" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:definition """Institution or organization officially appointed by a Registration
Authority to handle specific tasks within a defined area of
responsibility.
""" ;
    valuesets:category "governance" ;
    valuesets:examples "DataCite member organizations" .

DataCite:RegistrationAuthority a owl:Class ;
    rdfs:label "REGISTRATION_AUTHORITY" ;
    dcterms:title "Registration Authority" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:definition """A standards-setting body from which Registration Agencies obtain
their official recognition and guidance.
""" ;
    valuesets:category "governance" ;
    valuesets:examples "International DOI Foundation" .

DataCite:RelatedPerson a owl:Class ;
    rdfs:label "RELATED_PERSON" ;
    dcterms:title "Related Person" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:definition """A person without a specifically defined role in the development
of the resource, but who is someone the author wishes to recognize.
""" ;
    valuesets:category "acknowledgment" .

DataCite:Report a owl:Class ;
    rdfs:label "REPORT" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A document that presents information in an organized format
for a specific audience and purpose.
""" ;
    skos:exactMatch IAO:0000088,
        FABIO:TechnicalReport .

DataCite:Requires a owl:Class ;
    rdfs:label "REQUIRES" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A requires B." ;
    skos:exactMatch dcterms:requires ;
    valuesets:category "dependency" ;
    valuesets:inverse "IS_REQUIRED_BY" .

DataCite:ResearchGroup a owl:Class ;
    rdfs:label "RESEARCH_GROUP" ;
    dcterms:title "Research Group" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:definition """A group of individuals with a common research focus, typically
within a lab, department, or division.
""" ;
    valuesets:category "team" .

DataCite:Researcher a owl:Class ;
    rdfs:label "RESEARCHER" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:closeMatch CRediT:formal-analysis,
        CRediT:investigation ;
    skos:definition """A person involved in analyzing data or the results of an
experiment or formal study.
""" ;
    skos:exactMatch NCIt:C25741 ;
    valuesets:category "research" .

DataCite:Reviews a owl:Class ;
    rdfs:label "REVIEWS" ;
    rdfs:subClassOf valuesets:DataCiteRelationType ;
    skos:definition "Indicates that A is a review of B." ;
    skos:exactMatch cito:reviews ;
    valuesets:category "review" ;
    valuesets:inverse "IS_REVIEWED_BY" .

DataCite:RightsHolder a owl:Class ;
    rdfs:label "RIGHTS_HOLDER" ;
    dcterms:title "Rights Holder" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:definition """Person or institution owning or managing property rights,
including intellectual property rights, over the resource.
""" ;
    skos:exactMatch marcrel:own,
        NCIt:C54131 ;
    valuesets:category "legal" .

DataCite:Service a owl:Class ;
    rdfs:label "SERVICE" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """An organized system of apparatus, appliances, staff, etc.,
for supplying some function required by end users.
""" ;
    skos:exactMatch DCMITYPE:Service ;
    valuesets:examples "API, web service, data service" .

DataCite:Software a owl:Class ;
    rdfs:label "SOFTWARE" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A computer program other than a computational notebook,
in either source code (text) or compiled form.
""" ;
    skos:exactMatch DCMITYPE:Software .

DataCite:Sound a owl:Class ;
    rdfs:label "SOUND" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A resource primarily intended to be heard, including music,
speech, and other audio recordings.
""" ;
    skos:exactMatch DCMITYPE:Sound .

DataCite:Sponsor a owl:Class ;
    rdfs:label "SPONSOR" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:closeMatch CRediT:funding-acquisition ;
    skos:definition """Person or organization that issued a contract or under the
auspices of which a work has been written, printed, published,
developed, etc.
""" ;
    skos:exactMatch marcrel:spn ;
    valuesets:category "funding" .

DataCite:Standard a owl:Class ;
    rdfs:label "STANDARD" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """Something established by authority, custom, or general consent
as a model, example, or point of reference.
""" ;
    skos:exactMatch FABIO:Standard ;
    valuesets:examples "ISO standard, data format specification" .

DataCite:StudyRegistration a owl:Class ;
    rdfs:label "STUDY_REGISTRATION" ;
    dcterms:title "Study Registration" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A detailed, time-stamped description of a research plan,
often openly shared in a registry or repository.
""" ;
    valuesets:examples "clinical trial registration, pre-registration" .

DataCite:Supervisor a owl:Class ;
    rdfs:label "SUPERVISOR" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:closeMatch CRediT:supervision ;
    skos:definition """Designated administrator overseeing one or more groups or teams
working to produce the resource.
""" ;
    skos:exactMatch marcrel:ths ;
    valuesets:category "leadership" .

DataCite:Text a owl:Class ;
    rdfs:label "TEXT" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A resource consisting primarily of words for reading that is
not covered by any other textual resource type.
""" ;
    skos:exactMatch DCMITYPE:Text .

DataCite:Translator a owl:Class ;
    rdfs:label "TRANSLATOR" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:definition """Person, organization, or automated system responsible for
rendering the content of a resource from one language into
another.
""" ;
    skos:exactMatch marcrel:trl ;
    valuesets:added_version "4.6" ;
    valuesets:category "translation" .

DataCite:WorkPackageLeader a owl:Class ;
    rdfs:label "WORK_PACKAGE_LEADER" ;
    dcterms:title "Work Package Leader" ;
    rdfs:subClassOf valuesets:DataCiteContributorType ;
    skos:definition """A Work Package is a recognized data product, and the Work Package
Leader ensures the comprehensive contents, availability, and
quality of the work package.
""" ;
    valuesets:category "leadership" .

DataCite:Workflow a owl:Class ;
    rdfs:label "WORKFLOW" ;
    rdfs:subClassOf valuesets:DataCiteResourceType ;
    skos:definition """A structured series of steps which can be executed to produce
a final outcome, often automated.
""" ;
    valuesets:examples "bioinformatics pipeline, ETL workflow, analysis script" .

EC:1 a owl:Class ;
    rdfs:label "OXIDOREDUCTASE" ;
    dcterms:title "Oxidoreductases" ;
    rdfs:subClassOf valuesets:EnzymeClassEnum ;
    skos:definition "Catalyzes oxidation-reduction reactions" ;
    valuesets:EC_class "1" ;
    valuesets:examples "dehydrogenases, oxidases" .

EC:2 a owl:Class ;
    rdfs:label "TRANSFERASE" ;
    dcterms:title "Transferases" ;
    rdfs:subClassOf valuesets:EnzymeClassEnum ;
    skos:definition "Catalyzes group transfer reactions" ;
    valuesets:EC_class "2" ;
    valuesets:examples "kinases, transaminases" .

EC:3 a owl:Class ;
    rdfs:label "HYDROLASE" ;
    dcterms:title "Hydrolases" ;
    rdfs:subClassOf valuesets:EnzymeClassEnum ;
    skos:definition "Catalyzes hydrolysis reactions" ;
    valuesets:EC_class "3" ;
    valuesets:examples "proteases, lipases" .

EC:4 a owl:Class ;
    rdfs:label "LYASE" ;
    dcterms:title "Lyases" ;
    rdfs:subClassOf valuesets:EnzymeClassEnum ;
    skos:definition "Catalyzes non-hydrolytic additions/removals" ;
    valuesets:EC_class "4" ;
    valuesets:examples "decarboxylases, aldolases" .

EC:5 a owl:Class ;
    rdfs:label "ISOMERASE" ;
    dcterms:title "Isomerases" ;
    rdfs:subClassOf valuesets:EnzymeClassEnum ;
    skos:definition "Catalyzes isomerization reactions" ;
    valuesets:EC_class "5" ;
    valuesets:examples "racemases, epimerases" .

EC:6 a owl:Class ;
    rdfs:label "LIGASE" ;
    dcterms:title "Ligases" ;
    rdfs:subClassOf valuesets:EnzymeClassEnum ;
    skos:definition "Catalyzes formation of bonds with ATP" ;
    valuesets:EC_class "6" ;
    valuesets:examples "synthetases, carboxylases" .

EC:7 a owl:Class ;
    rdfs:label "TRANSLOCASE" ;
    dcterms:title "Translocases" ;
    rdfs:subClassOf valuesets:EnzymeClassEnum ;
    skos:definition "Catalyzes movement across membranes" ;
    valuesets:EC_class "7" ;
    valuesets:examples "ATPases, ion pumps" .

<https://ga4gh.org> a owl:Class ;
    rdfs:label "GA4GH" ;
    dcterms:title "Global Alliance for Genomics and Health" ;
    rdfs:subClassOf valuesets:ValueSetStewardEnum ;
    skos:altLabel "Global Alliance for Genomics and Health" ;
    skos:definition """International consortium developing standards for responsible sharing
of genomic and health-related data. Develops standards including
Phenopackets, VRS, DRS, and Beacon.
""" ;
    valuesets:established "2013" ;
    valuesets:headquarters "Multiple host institutions" ;
    valuesets:website "https://ga4gh.org" .

<https://geneontology.org> a owl:Class ;
    rdfs:label "GENE_ONTOLOGY_CONSORTIUM" ;
    dcterms:title "Gene Ontology Consortium" ;
    rdfs:subClassOf valuesets:ValueSetStewardEnum ;
    skos:altLabel "GO Consortium",
        "GOC" ;
    skos:definition """International consortium developing and maintaining the Gene Ontology,
the world's largest source of information on gene function. Provides
GO annotations and the GO ontology itself.
""" ;
    valuesets:established "1998" ;
    valuesets:website "https://geneontology.org" .

<https://gensc.org> a owl:Class ;
    rdfs:label "GENOMIC_STANDARDS_CONSORTIUM" ;
    dcterms:title "Genomic Standards Consortium" ;
    rdfs:subClassOf valuesets:ValueSetStewardEnum ;
    skos:altLabel "GSC" ;
    skos:definition """Open-membership community developing standards for describing genomes,
metagenomes, and related data. Develops MIxS checklists and related
metadata standards.
""" ;
    valuesets:established "2005" ;
    valuesets:website "https://gensc.org" .

<https://github.com/linkml/valuesets> a owl:Class ;
    rdfs:label "VALUESETS_PROJECT" ;
    dcterms:title "Valuesets Project" ;
    rdfs:subClassOf valuesets:ValueSetStewardEnum ;
