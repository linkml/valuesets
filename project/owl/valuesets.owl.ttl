HP:0012835 a owl:Class ;
    rdfs:label "LEFT" ;
    rdfs:subClassOf valuesets:LateralityEnum ;
    skos:definition "Left side" ;
    valuesets:anatomical_term "sinister" .

HP:0030674 a owl:Class ;
    rdfs:label "ANTENATAL_ONSET" ;
    rdfs:subClassOf valuesets:OnsetTimingEnum ;
    skos:definition "Before birth (prenatal)" ;
    valuesets:period "Before birth" .

HP:0032113 a owl:Class ;
    rdfs:label "SEMIDOMINANT" ;
    dcterms:title "Semidominant inheritance" ;
    rdfs:subClassOf valuesets:ModeOfInheritance ;
    skos:definition "A mode of inheritance for traits that can manifest in both monoallelic and biallelic states, with similar or differing phenotype severity." .

HP:0034340 a owl:Class ;
    rdfs:label "PSEUDOAUTOSOMAL_DOMINANT" ;
    dcterms:title "Pseudoautosomal dominant inheritance" ;
    rdfs:subClassOf HP:0034339,
        valuesets:ModeOfInheritance ;
    skos:definition "A type of pseudoautosomal inheritance that is dominant." .

HP:0034341 a owl:Class ;
    rdfs:label "PSEUDOAUTOSOMAL_RECESSIVE" ;
    dcterms:title "Pseudoautosomal recessive inheritance" ;
    rdfs:subClassOf HP:0034339,
        valuesets:ModeOfInheritance ;
    skos:definition "A type of pseudoautosomal inheritance that is recessive." .

HP:0034345 a owl:Class ;
    rdfs:label "MENDELIAN" ;
    dcterms:title "Mendelian inheritance" ;
    rdfs:subClassOf valuesets:ModeOfInheritance ;
    skos:definition "A mode of inheritance of diseases whose pathophysiology can be traced back to deleterious variants in a single gene." .

HsapDv:0000002 a owl:Class ;
    rdfs:label "EMBRYONIC_STAGE" ;
    dcterms:title "embryonic stage" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "Prenatal stage that starts with fertilization and ends with a fully formed embryo, before undergoing last development during the fetal stage. Up to 8 weeks post-fertilization." .

HsapDv:0000003 a owl:Class ;
    rdfs:label "ZYGOTE_STAGE" ;
    dcterms:title "Carnegie stage 01" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "Embryonic stage defined by a fertilized oocyte and presence of pronuclei. Starts at day 1 post-fertilization." .

HsapDv:0000005 a owl:Class ;
    rdfs:label "CLEAVAGE_STAGE" ;
    dcterms:title "Carnegie stage 02" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "Embryonic stage during which cell division occurs with reduction in cytoplasmic volume, and formation of inner and outer cell mass. 2-8 cells. Usually starts between day 2-3 post-fertilization." .

HsapDv:0000007 a owl:Class ;
    rdfs:label "BLASTOCYST_STAGE" ;
    dcterms:title "Carnegie stage 03" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "Blastula stage with the loss of the zona pellucida and the definition of a free blastocyst. Usually starts between day 4-5 post-fertilization." .

HsapDv:0000010 a owl:Class ;
    rdfs:label "GASTRULA_STAGE" ;
    dcterms:title "gastrula stage" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "Embryonic stage defined by a complex and coordinated series of cellular movements that occurs at the end of cleavage." .

HsapDv:0000012 a owl:Class ;
    rdfs:label "NEURULA_STAGE" ;
    dcterms:title "neurula stage" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "Embryonic stage defined by the formation of a tube from the flat layer of ectodermal cells known as the neural plate. This stage starts the emergence of the central nervous system." .

HsapDv:0000015 a owl:Class ;
    rdfs:label "ORGANOGENESIS_STAGE" ;
    dcterms:title "organogenesis stage" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "Embryonic stage at which the ectoderm, endoderm, and mesoderm develop into the internal organs of the organism." .

HsapDv:0000037 a owl:Class ;
    rdfs:label "FETAL_STAGE" ;
    dcterms:title "fetal stage" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "Prenatal stage that starts with the fully formed embryo and ends at birth. Generally from 8 weeks post-fertilization until birth." .

HsapDv:0000045 a owl:Class ;
    rdfs:label "PRENATAL_STAGE" ;
    dcterms:title "prenatal stage" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "Prenatal stage that starts with fertilization and ends at birth. Encompasses both embryonic and fetal stages." .

HsapDv:0000205 a owl:Class ;
    rdfs:label "MORULA_STAGE" ;
    dcterms:title "morula stage" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "The later part of Carnegie stage 02 when the cells have coalesced into a mass but the blastocystic cavity has not formed." .

HsapDv:0000227 a owl:Class ;
    rdfs:label "AGED_STAGE" ;
    dcterms:title "late adult stage" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "Late adult stage that refers to an individual who is over 60 and starts to have some age-related impairments. Often subdivided into young-old (60-79) and old-old (80+)." .

HsapDv:0000258 a owl:Class ;
    rdfs:label "ADULT_STAGE" ;
    dcterms:title "adult stage" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "Human developmental stage that refers to a sexually mature human. Starts at approximately 15 years according to HPO definitions." .

HsapDv:0000261 a owl:Class ;
    rdfs:label "INFANT_STAGE" ;
    dcterms:title "infant stage" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "Immature stage that refers to an infant who is over 28 days and is under 12 months old." .

HsapDv:0000262 a owl:Class ;
    rdfs:label "NEONATAL_STAGE" ;
    dcterms:title "newborn stage (0-28 days)" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "Immature stage that refers to a human newborn within the first 28 days of life." .

HsapDv:0000265 a owl:Class ;
    rdfs:label "TODDLER_STAGE" ;
    dcterms:title "child stage (1-4 yo)" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "Human stage that refers to a child who is over 12 months and under 5 years old. Often divided into early toddler (1-2 years) and late toddler (2-3 years)." .

HsapDv:0000268 a owl:Class ;
    rdfs:label "ADOLESCENT_STAGE" ;
    dcterms:title "15-19 year-old" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "A young adult stage that refers to an individual who is over 15 and under 20 years old. Period of transition from childhood to adulthood." .

HsapDv:0000271 a owl:Class ;
    rdfs:label "CHILD_STAGE" ;
    dcterms:title "juvenile stage (5-14 yo)" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "Pediatric stage that refers to a human who is over 5 and under 15 years old. Covers elementary and middle school ages." .

HsapDv:0010000 a owl:Class ;
    rdfs:label "POSTNATAL_STAGE" ;
    dcterms:title "postnatal stage" ;
    rdfs:subClassOf valuesets:HumanDevelopmentalStage ;
    skos:definition "Human developmental stage that covers the whole of human life post birth." .

