<https://w3id.org/valuesets/GeothermalResourceTemperature#SUPERCRITICAL> a owl:Class ;
    rdfs:label "SUPERCRITICAL" ;
    dcterms:title "Supercritical Resource" ;
    rdfs:subClassOf valuesets:GeothermalResourceTemperature ;
