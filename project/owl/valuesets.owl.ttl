    valuesets:competition "limited competition" ;
    valuesets:management "manageable complexity" ;
    valuesets:suppliers "two suppliers" .

<https://w3id.org/valuesets/SourcingStrategyEnum#GLOBAL_SOURCING> a owl:Class ;
