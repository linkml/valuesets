HP:0010982 a owl:Class ;
    rdfs:label "POLYGENIC" ;
    dcterms:title "Polygenic inheritance" ;
    rdfs:subClassOf HP:0001426,
        valuesets:ModeOfInheritance ;
    skos:definition "A mode of inheritance that depends on a mixture of major and minor genetic determinants possibly together with environmental factors." .

HP:0010983 a owl:Class ;
    rdfs:label "OLIGOGENIC" ;
    dcterms:title "Oligogenic inheritance" ;
    rdfs:subClassOf HP:0001426,
        valuesets:ModeOfInheritance ;
    skos:definition "A type of multifactorial inheritance governed by the simultaneous action of a few gene loci (typically three)." .

HP:0010984 a owl:Class ;
    rdfs:label "DIGENIC" ;
    dcterms:title "Digenic inheritance" ;
    rdfs:subClassOf HP:0001426,
        valuesets:ModeOfInheritance ;
    skos:definition "A type of multifactorial inheritance governed by the simultaneous action of two gene loci." .

HP:0011364 a owl:Class ;
    rdfs:label "WHITE" ;
    dcterms:title "White hair" ;
    rdfs:subClassOf valuesets:HairColorEnum ;
    skos:definition "White hair" ;
