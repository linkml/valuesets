valuesets:GeospatialFormatsSchemaEnum a owl:Class ;
    rdfs:label "GeospatialFormatsSchemaEnum" ;
    rdfs:subClassOf valuesets:ComputingDomainEnum ;
    skos:definition "Schema-level enum for geospatial_formats in computing" ;
    skos:inScheme valuesets:merged ;
    valuesets:source_file "computing/geospatial_formats.yaml" .

<https://w3id.org/valuesets/GeospatialRasterFormat#ASCII_GRID> a owl:Class ;
    rdfs:label "ASCII_GRID" ;
    dcterms:title "Esri ASCII Grid" ;
    rdfs:subClassOf valuesets:GeospatialRasterFormat ;
    skos:definition "Simple text-based raster format. Header followed by space-delimited cell values." ;
    valuesets:extension ".asc" ;
    valuesets:format "text" ;
    valuesets:organization "Esri" .

<https://w3id.org/valuesets/GeospatialRasterFormat#COG> a owl:Class ;
    rdfs:label "COG" ;
    dcterms:title "Cloud Optimized GeoTIFF" ;
    rdfs:subClassOf valuesets:GeospatialRasterFormat ;
    skos:definition "GeoTIFF optimized for cloud storage with internal tiling and overviews for efficient partial reads over HTTP." ;
    valuesets:extension ".tif" ;
    valuesets:features "cloud-optimized, COG" ;
    valuesets:georeferencing "embedded" ;
    valuesets:mime_type "image/tiff" .

<https://w3id.org/valuesets/GeospatialRasterFormat#ENVI> a owl:Class ;
    rdfs:label "ENVI" ;
    dcterms:title "ENVI" ;
    rdfs:subClassOf valuesets:GeospatialRasterFormat ;
    skos:definition "Format used by ENVI remote sensing software. Binary raster with separate header file." ;
    valuesets:extension ".dat, .bsq, .bil, .bip" ;
    valuesets:header ".hdr" .

<https://w3id.org/valuesets/GeospatialRasterFormat#ERDAS_IMAGINE> a owl:Class ;
    rdfs:label "ERDAS_IMAGINE" ;
    dcterms:title "ERDAS IMAGINE" ;
    rdfs:subClassOf valuesets:GeospatialRasterFormat ;
    skos:definition "Proprietary format for ERDAS IMAGINE software. Commonly used for satellite imagery processing." ;
    valuesets:extension ".img" ;
    valuesets:organization "Hexagon Geospatial" .

<https://w3id.org/valuesets/GeospatialRasterFormat#GEOTIFF> a owl:Class ;
    rdfs:label "GEOTIFF" ;
    dcterms:title "GeoTIFF" ;
    rdfs:subClassOf valuesets:GeospatialRasterFormat ;
    skos:definition "TIFF image format with embedded georeferencing information. Standard format for satellite imagery and raster GIS data." ;
    valuesets:extension ".tif, .tiff" ;
    valuesets:georeferencing "embedded" ;
    valuesets:mime_type "image/tiff" ;
    valuesets:organization "OGC" .

<https://w3id.org/valuesets/GeospatialRasterFormat#GRIB> a owl:Class ;
    rdfs:label "GRIB" ;
    dcterms:title "GRIB" ;
    rdfs:subClassOf valuesets:GeospatialRasterFormat ;
    skos:definition "GRIdded Binary format. Standard WMO format for meteorological data exchange." ;
    valuesets:extension ".grib, .grb, .grib2" ;
    valuesets:organization "WMO" ;
    valuesets:versions "GRIB1, GRIB2" .

<https://w3id.org/valuesets/GeospatialRasterFormat#HDF_EOS> a owl:Class ;
    rdfs:label "HDF_EOS" ;
    dcterms:title "HDF-EOS" ;
    rdfs:subClassOf valuesets:GeospatialRasterFormat ;
    skos:definition "HDF format extended for NASA Earth Observing System data. Used for MODIS, ASTER, and other NASA satellite products." ;
    valuesets:extension ".hdf" ;
    valuesets:organization "NASA" ;
    valuesets:variants "HDF-EOS2, HDF-EOS5" .

<https://w3id.org/valuesets/GeospatialRasterFormat#JPEG2000> a owl:Class ;
    rdfs:label "JPEG2000" ;
    dcterms:title "JPEG 2000" ;
    rdfs:subClassOf valuesets:GeospatialRasterFormat ;
    skos:definition "Wavelet-based image compression format with georeferencing capability. Used for satellite imagery distribution." ;
    valuesets:extension ".jp2, .j2k" ;
    valuesets:features "lossy/lossless compression" ;
    valuesets:mime_type "image/jp2" .

<https://w3id.org/valuesets/GeospatialRasterFormat#MRF> a owl:Class ;
    rdfs:label "MRF" ;
    dcterms:title "Meta Raster Format" ;
    rdfs:subClassOf valuesets:GeospatialRasterFormat ;
    skos:definition "NASA format optimized for cloud storage and fast random access to large imagery datasets." ;
    valuesets:extension ".mrf" ;
    valuesets:features "cloud-optimized" ;
    valuesets:organization "NASA" .

<https://w3id.org/valuesets/GeospatialRasterFormat#ZARR> a owl:Class ;
    rdfs:label "ZARR" ;
    dcterms:title "Zarr" ;
    rdfs:subClassOf valuesets:GeospatialRasterFormat ;
    skos:definition "Chunked, compressed, N-dimensional array format designed for cloud storage. Growing adoption for climate data." ;
    valuesets:extension ".zarr (directory)" ;
    valuesets:features "cloud-native, chunked" ;
    valuesets:python "zarr library" .

<https://w3id.org/valuesets/GeospatialVectorFormat#FLATGEOBUF> a owl:Class ;
    rdfs:label "FLATGEOBUF" ;
    dcterms:title "FlatGeobuf" ;
    rdfs:subClassOf valuesets:GeospatialVectorFormat ;
    skos:definition "Binary format optimized for fast streaming and random access. Cloud-native alternative to Shapefile." ;
    valuesets:extension ".fgb" ;
    valuesets:features "streaming, spatial index" .

<https://w3id.org/valuesets/GeospatialVectorFormat#GEODATABASE> a owl:Class ;
    rdfs:label "GEODATABASE" ;
    dcterms:title "Esri File Geodatabase" ;
    rdfs:subClassOf valuesets:GeospatialVectorFormat ;
    skos:definition "Esri proprietary format for storing multiple feature classes and tables in a folder structure." ;
    valuesets:extension ".gdb (folder)" ;
    valuesets:features "multiple layers, domains, relationships" ;
    valuesets:organization "Esri" .

<https://w3id.org/valuesets/GeospatialVectorFormat#GEOJSON> a owl:Class ;
    rdfs:label "GEOJSON" ;
    dcterms:title "GeoJSON" ;
    rdfs:subClassOf valuesets:GeospatialVectorFormat ;
    skos:definition "JSON-based format for encoding geographic data structures. Web-friendly and human-readable." ;
    valuesets:crs "WGS84 only" ;
    valuesets:extension ".geojson, .json" ;
    valuesets:mime_type "application/geo+json" ;
    valuesets:organization "IETF (RFC 7946)" .

<https://w3id.org/valuesets/GeospatialVectorFormat#GEOPACKAGE> a owl:Class ;
    rdfs:label "GEOPACKAGE" ;
    dcterms:title "GeoPackage" ;
    rdfs:subClassOf valuesets:GeospatialVectorFormat ;
    skos:definition "OGC standard SQLite-based format for vector and raster data. Modern replacement for Shapefile." ;
    valuesets:extension ".gpkg" ;
    valuesets:features "single file, no size limit, transactions" ;
    valuesets:organization "OGC" .

<https://w3id.org/valuesets/GeospatialVectorFormat#GEOPARQUET> a owl:Class ;
    rdfs:label "GEOPARQUET" ;
    dcterms:title "GeoParquet" ;
    rdfs:subClassOf valuesets:GeospatialVectorFormat ;
    skos:definition "Apache Parquet with geospatial extensions. Columnar format optimized for analytics on large vector datasets." ;
    valuesets:extension ".parquet" ;
    valuesets:features "columnar, cloud-optimized" .

<https://w3id.org/valuesets/GeospatialVectorFormat#GML> a owl:Class ;
    rdfs:label "GML" ;
    dcterms:title "GML" ;
    rdfs:subClassOf valuesets:GeospatialVectorFormat ;
    skos:definition "Geography Markup Language. OGC XML-based format for geographic features." ;
    valuesets:extension ".gml" ;
    valuesets:mime_type "application/gml+xml" ;
    valuesets:organization "OGC" .

<https://w3id.org/valuesets/GeospatialVectorFormat#GPKG_VECTOR> a owl:Class ;
    rdfs:label "GPKG_VECTOR" ;
    dcterms:title "GeoPackage (Vector)" ;
    rdfs:subClassOf valuesets:GeospatialVectorFormat ;
    skos:definition "Vector data stored in GeoPackage format. Can coexist with raster data in same file." ;
    valuesets:extension ".gpkg" ;
    valuesets:organization "OGC" .

<https://w3id.org/valuesets/GeospatialVectorFormat#KML> a owl:Class ;
    rdfs:label "KML" ;
    dcterms:title "KML" ;
    rdfs:subClassOf valuesets:GeospatialVectorFormat ;
    skos:definition "Keyhole Markup Language. XML-based format for Google Earth and other applications." ;
    valuesets:extension ".kml" ;
    valuesets:mime_type "application/vnd.google-earth.kml+xml" ;
    valuesets:organization "OGC (originally Google)" .

<https://w3id.org/valuesets/GeospatialVectorFormat#KMZ> a owl:Class ;
    rdfs:label "KMZ" ;
    dcterms:title "KMZ" ;
    rdfs:subClassOf valuesets:GeospatialVectorFormat ;
    skos:definition "Compressed KML file (ZIP archive containing KML and supporting files)." ;
    valuesets:compression "ZIP" ;
    valuesets:extension ".kmz" ;
    valuesets:mime_type "application/vnd.google-earth.kmz" .

<https://w3id.org/valuesets/GeospatialVectorFormat#SHAPEFILE> a owl:Class ;
    rdfs:label "SHAPEFILE" ;
    dcterms:title "Esri Shapefile" ;
    rdfs:subClassOf valuesets:GeospatialVectorFormat ;
    skos:definition "Widely used vector format consisting of multiple files (.shp, .shx, .dbf). De facto standard despite limitations." ;
    valuesets:extension ".shp (+ .shx, .dbf, .prj)" ;
    valuesets:limitations "2GB size limit, 10-char field names" ;
    valuesets:organization "Esri" .

<https://w3id.org/valuesets/GeospatialVectorFormat#TOPOJSON> a owl:Class ;
    rdfs:label "TOPOJSON" ;
    dcterms:title "TopoJSON" ;
    rdfs:subClassOf valuesets:GeospatialVectorFormat ;
    skos:definition "Extension of GeoJSON that encodes topology. Smaller file sizes through shared arc representation." ;
    valuesets:extension ".topojson, .json" ;
    valuesets:features "topology encoding, smaller files" .

<https://w3id.org/valuesets/GeospatialVectorFormat#WKB> a owl:Class ;
    rdfs:label "WKB" ;
    dcterms:title "Well-Known Binary" ;
    rdfs:subClassOf valuesets:GeospatialVectorFormat ;
    skos:definition "Binary equivalent of WKT for efficient storage and transfer." ;
    valuesets:format "binary" ;
    valuesets:organization "OGC" .

<https://w3id.org/valuesets/GeospatialVectorFormat#WKT> a owl:Class ;
    rdfs:label "WKT" ;
    dcterms:title "Well-Known Text" ;
    rdfs:subClassOf valuesets:GeospatialVectorFormat ;
    skos:definition "Text markup language for representing vector geometry objects." ;
    valuesets:format "text" ;
    valuesets:organization "OGC" ;
    valuesets:use "geometry representation" .

