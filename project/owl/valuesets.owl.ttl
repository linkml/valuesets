    valuesets:collaboration "multi-organization collaboration" ;
    valuesets:complexity "coordination complexity" ;
    valuesets:cost "cost reduction through scale" ;
    valuesets:leverage "increased buying leverage" ;
    valuesets:relationships "multi-party relationships" .

<https://w3id.org/valuesets/SourcingStrategyEnum#DOMESTIC_SOURCING> a owl:Class ;
