    valuesets:temperature_max_c 90 .

<https://w3id.org/valuesets/GeothermalResourceTemperature#MODERATE_TEMPERATURE> a owl:Class ;
    rdfs:label "MODERATE_TEMPERATURE" ;
    dcterms:title "Moderate Temperature Resource" ;
    rdfs:subClassOf valuesets:GeothermalResourceTemperature ;
