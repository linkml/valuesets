<https://w3id.org/valuesets/SpatialResolutionEnum#BUFFER_5KM> a owl:Class ;
    rdfs:label "BUFFER_5KM" ;
    dcterms:title "5 kilometer buffer" ;
    rdfs:subClassOf valuesets:SpatialResolutionEnum ;
    skos:definition "Circular buffer of 5 kilometers around a point." ;
    valuesets:radius "5 km" .

