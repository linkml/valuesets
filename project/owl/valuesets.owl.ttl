<https://w3id.org/valuesets/HydrogeologyWellType#RECHARGE_WELL> a owl:Class ;
    rdfs:label "RECHARGE_WELL" ;
    rdfs:subClassOf valuesets:HydrogeologyWellType ;
    skos:definition "A well used to artificially replenish groundwater by injecting treated water into an aquifer" .

<https://w3id.org/valuesets/IAEAWasteClassificationEnum#EXEMPT_WASTE> a owl:Class ;
    rdfs:label "EXEMPT_WASTE" ;
    dcterms:title "Exempt Waste (EW)" ;
    rdfs:subClassOf valuesets:IAEAWasteClassificationEnum ;
    skos:altLabel "EW" ;
    skos:definition "Waste with negligible radioactivity requiring no regulatory control" ;
    valuesets:activity_level "negligible" ;
    valuesets:clearance "can be cleared from regulatory control" ;
    valuesets:disposal "as ordinary waste" ;
    valuesets:regulatory_control "none required" .

<https://w3id.org/valuesets/IAEAWasteClassificationEnum#HIGH_LEVEL_WASTE> a owl:Class ;
    rdfs:label "HIGH_LEVEL_WASTE" ;
    dcterms:title "High Level Waste (HLW)" ;
    rdfs:subClassOf valuesets:IAEAWasteClassificationEnum ;
    skos:altLabel "HLW" ;
    skos:definition "Waste requiring containment for thousands to hundreds of thousands of years" ;
    valuesets:activity_level "high" ;
    valuesets:containment_period "thousands to hundreds of thousands of years" ;
    valuesets:cooling "required" ;
    valuesets:disposal "geological disposal" ;
    valuesets:heat_generation "significant (>2 kW/m³)" ;
    valuesets:shielding "heavy shielding required" .

<https://w3id.org/valuesets/IAEAWasteClassificationEnum#INTERMEDIATE_LEVEL_WASTE> a owl:Class ;
    rdfs:label "INTERMEDIATE_LEVEL_WASTE" ;
    dcterms:title "Intermediate Level Waste (ILW)" ;
    rdfs:subClassOf valuesets:IAEAWasteClassificationEnum ;
    skos:altLabel "ILW" ;
    skos:definition "Waste requiring containment for thousands of years" ;
    valuesets:activity_level "intermediate" ;
    valuesets:containment_period "up to thousands of years" ;
    valuesets:disposal "geological disposal" ;
    valuesets:heat_generation "low (<2 kW/m³)" ;
    valuesets:shielding "required" .

<https://w3id.org/valuesets/IAEAWasteClassificationEnum#LOW_LEVEL_WASTE> a owl:Class ;
    rdfs:label "LOW_LEVEL_WASTE" ;
    dcterms:title "Low Level Waste (LLW)" ;
    rdfs:subClassOf valuesets:IAEAWasteClassificationEnum ;
    skos:altLabel "LLW" ;
    skos:definition "Waste requiring containment for up to hundreds of years" ;
    valuesets:activity_level "low" ;
    valuesets:containment_period "up to few hundred years" ;
    valuesets:disposal "near-surface disposal" ;
    valuesets:heat_generation "negligible" .

<https://w3id.org/valuesets/IAEAWasteClassificationEnum#VERY_LOW_LEVEL_WASTE> a owl:Class ;
    rdfs:label "VERY_LOW_LEVEL_WASTE" ;
    dcterms:title "Very Low Level Waste (VLLW)" ;
    rdfs:subClassOf valuesets:IAEAWasteClassificationEnum ;
    skos:altLabel "VLLW" ;
    skos:definition "Waste requiring limited containment and isolation" ;
    valuesets:activity_level "very low but above exempt" ;
    valuesets:containment_requirement "limited" ;
    valuesets:disposal "near-surface landfill-type" ;
    valuesets:isolation_period "limited" .

<https://w3id.org/valuesets/IAEAWasteClassificationEnum#VERY_SHORT_LIVED_WASTE> a owl:Class ;
    rdfs:label "VERY_SHORT_LIVED_WASTE" ;
    dcterms:title "Very Short-Lived Waste (VSLW)" ;
    rdfs:subClassOf valuesets:IAEAWasteClassificationEnum ;
    skos:altLabel "VSLW" ;
    skos:definition "Waste stored for decay to exempt levels within few years" ;
    valuesets:clearance "after decay period" ;
    valuesets:decay_strategy "storage for decay" ;
    valuesets:storage_period "up to few years" ;
    valuesets:typical_sources "medical, research isotopes" .

<https://w3id.org/valuesets/IARCCarcinogenicityGroup#GROUP_1> a owl:Class ;
    rdfs:label "GROUP_1" ;
    dcterms:title "Carcinogenic to humans" ;
    rdfs:subClassOf valuesets:IARCCarcinogenicityGroup ;
    skos:definition "Sufficient evidence of carcinogenicity in humans. The agent is carcinogenic to humans." ;
    valuesets:evidence_level "sufficient in humans" ;
    valuesets:examples "asbestos, benzene, tobacco smoking, ionizing radiation" .

<https://w3id.org/valuesets/IARCCarcinogenicityGroup#GROUP_2A> a owl:Class ;
    rdfs:label "GROUP_2A" ;
    dcterms:title "Probably carcinogenic to humans" ;
    rdfs:subClassOf valuesets:IARCCarcinogenicityGroup ;
    skos:definition "Limited evidence of carcinogenicity in humans and sufficient evidence in experimental animals. The agent is probably carcinogenic to humans." ;
    valuesets:evidence_level "limited in humans, sufficient in animals" ;
    valuesets:examples "red meat, night shift work, glyphosate" .

<https://w3id.org/valuesets/IARCCarcinogenicityGroup#GROUP_2B> a owl:Class ;
    rdfs:label "GROUP_2B" ;
    dcterms:title "Possibly carcinogenic to humans" ;
    rdfs:subClassOf valuesets:IARCCarcinogenicityGroup ;
    skos:definition "Limited evidence of carcinogenicity in humans and less than sufficient evidence in experimental animals. The agent is possibly carcinogenic to humans." ;
    valuesets:evidence_level "limited in humans or animals" ;
    valuesets:examples "coffee, pickled vegetables, gasoline engine exhaust" .

<https://w3id.org/valuesets/IARCCarcinogenicityGroup#GROUP_3> a owl:Class ;
    rdfs:label "GROUP_3" ;
    dcterms:title "Not classifiable as to carcinogenicity" ;
    rdfs:subClassOf valuesets:IARCCarcinogenicityGroup ;
    skos:definition "Inadequate evidence of carcinogenicity in humans and inadequate or limited evidence in experimental animals. The agent is not classifiable as to its carcinogenicity to humans." ;
    valuesets:evidence_level "inadequate" ;
    valuesets:examples "caffeine, cholesterol, saccharin" .

<https://w3id.org/valuesets/INESLevelEnum#LEVEL_0> a owl:Class ;
    rdfs:label "LEVEL_0" ;
    dcterms:title "Level 0 - Below Scale/Deviation" ;
    rdfs:subClassOf valuesets:INESLevelEnum ;
    skos:definition "Events without safety significance" ;
    valuesets:examples "minor technical issues" ;
    valuesets:public_impact "none" ;
    valuesets:safety_significance "no safety significance" ;
    valuesets:scale_position "below scale" .

<https://w3id.org/valuesets/INESLevelEnum#LEVEL_1> a owl:Class ;
    rdfs:label "LEVEL_1" ;
    dcterms:title "Level 1 - Anomaly" ;
    rdfs:subClassOf valuesets:INESLevelEnum ;
    skos:definition "Anomaly beyond authorized operating regime" ;
    valuesets:examples "minor contamination, minor safety system failure" ;
    valuesets:public_impact "none" ;
    valuesets:safety_significance "minor" ;
    valuesets:scale_position "incidents" .

<https://w3id.org/valuesets/INESLevelEnum#LEVEL_2> a owl:Class ;
    rdfs:label "LEVEL_2" ;
    dcterms:title "Level 2 - Incident" ;
    rdfs:subClassOf valuesets:INESLevelEnum ;
    skos:definition "Incident with significant defenses remaining" ;
    valuesets:public_impact "none" ;
    valuesets:radiation_dose "<10 mSv to workers" ;
    valuesets:safety_significance "minor" ;
    valuesets:scale_position "incidents" .

<https://w3id.org/valuesets/INESLevelEnum#LEVEL_3> a owl:Class ;
    rdfs:label "LEVEL_3" ;
    dcterms:title "Level 3 - Serious Incident" ;
    rdfs:subClassOf valuesets:INESLevelEnum ;
    skos:definition "Serious incident with some defense degradation" ;
    valuesets:examples "near accident, serious contamination" ;
    valuesets:public_impact "very minor" ;
    valuesets:radiation_dose "<100 mSv to workers" ;
    valuesets:safety_significance "minor" ;
    valuesets:scale_position "incidents" .

<https://w3id.org/valuesets/INESLevelEnum#LEVEL_4> a owl:Class ;
    rdfs:label "LEVEL_4" ;
    dcterms:title "Level 4 - Accident with Local Consequences" ;
    rdfs:subClassOf valuesets:INESLevelEnum ;
    skos:definition "Accident with minor off-site releases" ;
    valuesets:evacuation "not required" ;
    valuesets:examples "partial core damage" ;
    valuesets:public_impact "minor local impact" ;
    valuesets:safety_significance "moderate" ;
    valuesets:scale_position "accidents" .

<https://w3id.org/valuesets/INESLevelEnum#LEVEL_5> a owl:Class ;
    rdfs:label "LEVEL_5" ;
    dcterms:title "Level 5 - Accident with Wider Consequences" ;
    rdfs:subClassOf valuesets:INESLevelEnum ;
    skos:definition "Accident with limited off-site releases" ;
    valuesets:examples "Three Mile Island (1979)" ;
    valuesets:protective_actions "limited evacuation" ;
    valuesets:public_impact "limited wider impact" ;
    valuesets:safety_significance "moderate to major" ;
    valuesets:scale_position "accidents" .

<https://w3id.org/valuesets/INESLevelEnum#LEVEL_6> a owl:Class ;
    rdfs:label "LEVEL_6" ;
    dcterms:title "Level 6 - Serious Accident" ;
    rdfs:subClassOf valuesets:INESLevelEnum ;
    skos:definition "Serious accident with significant releases" ;
    valuesets:protective_actions "extensive evacuation and countermeasures" ;
    valuesets:public_impact "significant" ;
    valuesets:safety_significance "major" ;
    valuesets:scale_position "accidents" .

<https://w3id.org/valuesets/INESLevelEnum#LEVEL_7> a owl:Class ;
    rdfs:label "LEVEL_7" ;
    dcterms:title "Level 7 - Major Accident" ;
    rdfs:subClassOf valuesets:INESLevelEnum ;
    skos:definition "Major accident with widespread health and environmental effects" ;
    valuesets:consequences "long-term environmental contamination" ;
    valuesets:examples "Chernobyl (1986), Fukushima (2011)" ;
    valuesets:public_impact "widespread" ;
    valuesets:safety_significance "major" ;
    valuesets:scale_position "accidents" .

