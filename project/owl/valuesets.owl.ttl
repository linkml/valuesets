<https://w3id.org/valuesets/HydrogenApplication#FUEL_CELL_STATIONARY> a owl:Class ;
    rdfs:label "FUEL_CELL_STATIONARY" ;
    dcterms:title "Stationary Fuel Cell" ;
    rdfs:subClassOf valuesets:HydrogenApplication ;
    skos:definition "Use of hydrogen in stationary fuel cells for power generation." .

<https://w3id.org/valuesets/HydrogenApplication#FUEL_CELL_VEHICLE> a owl:Class ;
    rdfs:label "FUEL_CELL_VEHICLE" ;
    dcterms:title "Fuel Cell Electric Vehicle" ;
    rdfs:subClassOf valuesets:HydrogenApplication ;
    skos:altLabel "FCEV" ;
    skos:definition "Use of hydrogen in fuel cells for transportation (cars, trucks, buses)." .

<https://w3id.org/valuesets/HydrogenApplication#INDUSTRIAL_FEEDSTOCK> a owl:Class ;
    rdfs:label "INDUSTRIAL_FEEDSTOCK" ;
    dcterms:title "Industrial Feedstock" ;
    rdfs:subClassOf valuesets:HydrogenApplication ;
    skos:definition "Use of hydrogen as chemical feedstock for ammonia production, petroleum refining, and chemical synthesis." .

<https://w3id.org/valuesets/HydrogenApplication#METHANOL_SYNTHESIS> a owl:Class ;
    rdfs:label "METHANOL_SYNTHESIS" ;
    dcterms:title "Methanol Synthesis" ;
    rdfs:subClassOf valuesets:HydrogenApplication ;
    skos:definition "Use of hydrogen with CO2 to produce methanol." ;
    skos:relatedMatch <http://sweetontology.net/matrOrganicCompound/Methanol> .

<https://w3id.org/valuesets/HydrogenApplication#POWER_TO_GAS> a owl:Class ;
    rdfs:label "POWER_TO_GAS" ;
    dcterms:title "Power-to-Gas" ;
    rdfs:subClassOf valuesets:HydrogenApplication ;
    skos:altLabel "P2G" ;
    skos:definition "Conversion of excess renewable electricity to hydrogen for grid balancing and energy storage." .

<https://w3id.org/valuesets/HydrogenApplication#STEEL_PRODUCTION> a owl:Class ;
    rdfs:label "STEEL_PRODUCTION" ;
    dcterms:title "Steel Production (Direct Reduction)" ;
    rdfs:subClassOf valuesets:HydrogenApplication ;
    skos:altLabel "Green Steel" ;
    skos:definition "Use of hydrogen to reduce iron ore in steelmaking, replacing coal." .

<https://w3id.org/valuesets/HydrogenApplication#SYNTHETIC_FUELS> a owl:Class ;
    rdfs:label "SYNTHETIC_FUELS" ;
    dcterms:title "Synthetic Fuel Production" ;
    rdfs:subClassOf valuesets:HydrogenApplication ;
    skos:altLabel "E-Fuels",
        "Power-to-Liquid" ;
    skos:definition "Use of hydrogen with captured CO2 to produce synthetic hydrocarbons (e-fuels, SAF)." .

<https://w3id.org/valuesets/HydrogenProductionMethod#ALKALINE_ELECTROLYSIS> a owl:Class ;
    rdfs:label "ALKALINE_ELECTROLYSIS" ;
    dcterms:title "Alkaline Electrolysis (AEL)" ;
    rdfs:subClassOf valuesets:HydrogenProductionMethod ;
    skos:altLabel "AEL" ;
    skos:definition "Electrolysis using alkaline solution (typically KOH) as electrolyte. Mature commercial technology." ;
    valuesets:electrolyte "alkaline" ;
    valuesets:maturity "commercial" .

<https://w3id.org/valuesets/HydrogenProductionMethod#AUTOTHERMAL_REFORMING> a owl:Class ;
    rdfs:label "AUTOTHERMAL_REFORMING" ;
    dcterms:title "Autothermal Reforming (ATR)" ;
    rdfs:subClassOf valuesets:HydrogenProductionMethod ;
    skos:altLabel "ATR" ;
    skos:definition "Combines steam reforming and partial oxidation using oxygen and steam to produce hydrogen from hydrocarbons." .

<https://w3id.org/valuesets/HydrogenProductionMethod#BIOLOGICAL_PRODUCTION> a owl:Class ;
    rdfs:label "BIOLOGICAL_PRODUCTION" ;
    dcterms:title "Biological Hydrogen Production" ;
    rdfs:subClassOf valuesets:HydrogenProductionMethod ;
    skos:altLabel "Biohydrogen" ;
    skos:definition "Production of hydrogen by microorganisms through photosynthesis, fermentation, or other biological processes." ;
    valuesets:maturity "research" ;
    valuesets:renewable true .

<https://w3id.org/valuesets/HydrogenProductionMethod#BIOMASS_GASIFICATION> a owl:Class ;
    rdfs:label "BIOMASS_GASIFICATION" ;
    dcterms:title "Biomass Gasification" ;
    rdfs:subClassOf valuesets:HydrogenProductionMethod ;
