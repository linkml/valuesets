    valuesets:co2_per_kg_h2 "9-12" ;
    valuesets:energy_source "natural_gas" ;
    valuesets:production_method "steam_methane_reforming" .

<https://w3id.org/valuesets/HydrogenType#ORANGE_HYDROGEN> a owl:Class ;
