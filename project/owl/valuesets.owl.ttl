<https://w3id.org/valuesets/GeothermalReservoirType#MAGMATIC> a owl:Class ;
    rdfs:label "MAGMATIC" ;
    dcterms:title "Magmatic/Near-Magmatic Reservoir" ;
    rdfs:subClassOf valuesets:GeothermalReservoirType ;
