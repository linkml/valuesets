xsd:anyURI a owl:Class ;
    rdfs:label "URL" ;
    rdfs:subClassOf valuesets:MLDataType ;
    skos:definition "Uniform Resource Locators" ;
    skos:mappingRelation schema1:URL .

xsd:boolean a owl:Class ;
    rdfs:label "BOOLEAN" ;
    rdfs:subClassOf valuesets:MLDataType ;
    skos:definition "Boolean values (true/false)" ;
    skos:mappingRelation schema1:Boolean .

xsd:date a owl:Class ;
    rdfs:label "DATE" ;
    rdfs:subClassOf valuesets:MLDataType ;
    skos:definition "Date values" ;
    skos:mappingRelation schema1:Date .

xsd:dateTime a owl:Class ;
    rdfs:label "DATETIME" ;
    rdfs:subClassOf valuesets:MLDataType ;
    skos:definition "Combined date and time values" ;
    skos:mappingRelation schema1:DateTime .

xsd:float a owl:Class ;
    rdfs:label "FLOAT" ;
    rdfs:subClassOf valuesets:MLDataType ;
    skos:definition "Floating point numbers" ;
    skos:mappingRelation schema1:Float .

xsd:integer a owl:Class ;
    rdfs:label "INTEGER" ;
    rdfs:subClassOf valuesets:MLDataType ;
    skos:definition "Integer numbers" ;
    skos:mappingRelation IAO:0000031,
        schema1:Integer .

xsd:string a owl:Class ;
    rdfs:label "TEXT" ;
    rdfs:subClassOf valuesets:MLDataType ;
    skos:definition "Text or string data" ;
    skos:mappingRelation EDAM:3671,
        schema1:Text .

xsd:time a owl:Class ;
    rdfs:label "TIME" ;
    rdfs:subClassOf valuesets:MLDataType ;
    skos:definition "Time values" ;
    skos:mappingRelation schema1:Time .

TIME:Friday a owl:Class ;
    rdfs:label "FRIDAY" ;
    rdfs:subClassOf valuesets:DayOfWeek ;
    skos:definition "Friday" ;
    skos:exactMatch NCIt:C64966,
        OPMI:0000088 ;
    valuesets:abbreviation "Fri" ;
    valuesets:iso_number 5 .

TIME:Monday a owl:Class ;
    rdfs:label "MONDAY" ;
    rdfs:subClassOf valuesets:DayOfWeek ;
    skos:definition "Monday (first day of week in ISO 8601)" ;
    skos:exactMatch NCIt:C64962,
        OPMI:0000084 ;
    valuesets:abbreviation "Mon" ;
    valuesets:iso_number 1 .

TIME:Saturday a owl:Class ;
    rdfs:label "SATURDAY" ;
    rdfs:subClassOf valuesets:DayOfWeek ;
    skos:definition "Saturday" ;
    skos:exactMatch NCIt:C64967,
        OPMI:0000089 ;
    valuesets:abbreviation "Sat" ;
    valuesets:iso_number 6 .

TIME:Sunday a owl:Class ;
    rdfs:label "SUNDAY" ;
    rdfs:subClassOf valuesets:DayOfWeek ;
    skos:definition "Sunday (last day of week in ISO 8601)" ;
    skos:exactMatch NCIt:C64968,
        OPMI:0000090 ;
    valuesets:abbreviation "Sun" ;
    valuesets:iso_number 7 .

TIME:Thursday a owl:Class ;
    rdfs:label "THURSDAY" ;
    rdfs:subClassOf valuesets:DayOfWeek ;
    skos:definition "Thursday" ;
    skos:exactMatch NCIt:C64965,
        OPMI:0000087 ;
    valuesets:abbreviation "Thu" ;
    valuesets:iso_number 4 .

TIME:Tuesday a owl:Class ;
    rdfs:label "TUESDAY" ;
    rdfs:subClassOf valuesets:DayOfWeek ;
    skos:definition "Tuesday" ;
    skos:exactMatch NCIt:C64963,
        OPMI:0000085 ;
    valuesets:abbreviation "Tue" ;
    valuesets:iso_number 2 .

TIME:Wednesday a owl:Class ;
    rdfs:label "WEDNESDAY" ;
    rdfs:subClassOf valuesets:DayOfWeek ;
    skos:definition "Wednesday" ;
    skos:exactMatch NCIt:C64964,
        OPMI:0000086 ;
    valuesets:abbreviation "Wed" ;
    valuesets:iso_number 3 .

adms:Completed a owl:Class ;
    rdfs:label "COMPLETED" ;
    rdfs:subClassOf valuesets:DatasetStatus ;
    skos:altLabel "Final",
        "Finished" ;
    skos:definition """The dataset is complete and no further updates are planned.
The data is in its final form.
""" .

adms:Deprecated a owl:Class ;
    rdfs:label "DEPRECATED" ;
    rdfs:subClassOf valuesets:DatasetStatus ;
    skos:altLabel "Legacy",
        "Superseded" ;
    skos:definition """The dataset has been superseded by a newer version or is
no longer recommended for use.
""" .

adms:UnderDevelopment a owl:Class ;
    rdfs:label "UNDER_DEVELOPMENT" ;
    dcterms:title "Under Development" ;
    rdfs:subClassOf valuesets:DatasetStatus ;
    skos:altLabel "Draft",
        "In Progress",
        "Work in Progress" ;
    skos:definition """The dataset is still being created, collected, or processed.
Not yet ready for production use.
""" .

adms:Withdrawn a owl:Class ;
    rdfs:label "WITHDRAWN" ;
    rdfs:subClassOf valuesets:DatasetStatus ;
    skos:altLabel "Removed",
        "Retracted" ;
    skos:definition """The dataset has been removed from availability, either
temporarily or permanently.
""" .

