    valuesets:partnership "close partnership" ;
    valuesets:risk "supply concentration risk" ;
    valuesets:strategic "strategic decision" ;
    valuesets:suppliers "single supplier" .

<https://w3id.org/valuesets/SourcingStrategyEnum#VERTICAL_INTEGRATION> a owl:Class ;
