<https://w3id.org/valuesets/GeothermalReservoirType#CONDUCTION_DOMINATED> a owl:Class ;
    rdfs:label "CONDUCTION_DOMINATED" ;
    dcterms:title "Conduction-Dominated Reservoir" ;
    rdfs:subClassOf valuesets:GeothermalReservoirType ;
