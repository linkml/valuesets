<https://w3id.org/valuesets/CryptographicHashFunction#BLAKE2B_256> a owl:Class ;
    rdfs:label "BLAKE2B_256" ;
    dcterms:title "BLAKE2b-256" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """BLAKE2b variant producing a 256-bit hash value.
Faster than MD5 and SHA-1 while being more secure.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_blake2b256 ;
    valuesets:output_bits 256 ;
    valuesets:security_level "secure" .

<https://w3id.org/valuesets/CryptographicHashFunction#BLAKE2B_384> a owl:Class ;
    rdfs:label "BLAKE2B_384" ;
    dcterms:title "BLAKE2b-384" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """BLAKE2b variant producing a 384-bit hash value.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_blake2b384 ;
    valuesets:output_bits 384 ;
    valuesets:security_level "secure" .

<https://w3id.org/valuesets/CryptographicHashFunction#BLAKE2B_512> a owl:Class ;
    rdfs:label "BLAKE2B_512" ;
    dcterms:title "BLAKE2b-512" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """BLAKE2b variant producing a 512-bit hash value.
Optimized for 64-bit platforms.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_blake2b512 ;
    valuesets:output_bits 512 ;
    valuesets:security_level "secure" .

<https://w3id.org/valuesets/CryptographicHashFunction#BLAKE3> a owl:Class ;
    rdfs:label "BLAKE3" ;
    dcterms:title "BLAKE3" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """Latest BLAKE variant, extremely fast with 256-bit output.
Supports parallelization and incremental hashing.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_blake3 ;
    valuesets:output_bits 256 ;
    valuesets:security_level "secure" .

<https://w3id.org/valuesets/CryptographicHashFunction#MD4> a owl:Class ;
    rdfs:label "MD4" ;
    dcterms:title "MD4" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """Message Digest 4 algorithm producing a 128-bit hash value.
Predecessor to MD5. Considered cryptographically broken.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_md4 ;
    valuesets:output_bits 128 ;
    valuesets:security_level "broken" .

<https://w3id.org/valuesets/CryptographicHashFunction#MD6> a owl:Class ;
    rdfs:label "MD6" ;
    dcterms:title "MD6" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """Message Digest 6 algorithm with variable output size.
Designed as a candidate for SHA-3 but not selected.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_md6 ;
    valuesets:output_bits "variable" ;
    valuesets:security_level "adequate" .

<https://w3id.org/valuesets/CryptographicHashFunction#SHA3_224> a owl:Class ;
    rdfs:label "SHA3_224" ;
    dcterms:title "SHA3-224" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """SHA-3 variant producing a 224-bit hash value.
Based on the Keccak algorithm.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_sha3_224 ;
    valuesets:output_bits 224 ;
    valuesets:security_level "secure" .

<https://w3id.org/valuesets/CryptographicHashFunction#SHA3_256> a owl:Class ;
    rdfs:label "SHA3_256" ;
    dcterms:title "SHA3-256" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """SHA-3 variant producing a 256-bit hash value.
Based on the Keccak algorithm. Provides defense against
length extension attacks.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_sha3_256 ;
    valuesets:output_bits 256 ;
    valuesets:security_level "secure" .

<https://w3id.org/valuesets/CryptographicHashFunction#SHA3_384> a owl:Class ;
    rdfs:label "SHA3_384" ;
    dcterms:title "SHA3-384" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """SHA-3 variant producing a 384-bit hash value.
Based on the Keccak algorithm.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_sha3_384 ;
    valuesets:output_bits 384 ;
    valuesets:security_level "secure" .

<https://w3id.org/valuesets/CryptographicHashFunction#SHA3_512> a owl:Class ;
    rdfs:label "SHA3_512" ;
    dcterms:title "SHA3-512" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:definition """SHA-3 variant producing a 512-bit hash value.
Based on the Keccak algorithm.
""" ;
    skos:exactMatch spdx:checksumAlgorithm_sha3_512 ;
    valuesets:output_bits 512 ;
    valuesets:security_level "secure" .

<https://w3id.org/valuesets/CryptographicHashFunction#SHA_224> a owl:Class ;
    rdfs:label "SHA_224" ;
    dcterms:title "SHA-224" ;
    rdfs:subClassOf valuesets:CryptographicHashFunction ;
    skos:altLabel "SHA224" ;
