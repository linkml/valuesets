    rdfs:subClassOf valuesets:SpatialResolutionEnum ;
    skos:definition "Circular buffer of 1 kilometer around a point." ;
    valuesets:radius "1 km" .

<https://w3id.org/valuesets/SpatialResolutionEnum#BUFFER_500M> a owl:Class ;
