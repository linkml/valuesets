<https://w3id.org/valuesets/ExtremeWeatherEventEnum#COLD_WAVE> a owl:Class ;
    rdfs:label "COLD_WAVE" ;
    dcterms:title "Cold wave" ;
    rdfs:subClassOf valuesets:ExtremeWeatherEventEnum ;
    skos:definition "Prolonged period of excessively cold weather relative to the expected conditions for a given area. Associated with hypothermia and cardiovascular events." ;
    valuesets:health_impacts "hypothermia, cardiovascular events, frostbite" .

<https://w3id.org/valuesets/ExtremeWeatherEventEnum#DUST_STORM> a owl:Class ;
    rdfs:label "DUST_STORM" ;
    dcterms:title "Dust storm" ;
    rdfs:subClassOf valuesets:ExtremeWeatherEventEnum ;
    skos:definition "Meteorological event with strong winds lifting large amounts of sand and dust into the atmosphere. Reduces visibility and air quality." ;
    valuesets:health_impacts "respiratory illness, traffic accidents" ;
    valuesets:related "haboob, sandstorm" .

<https://w3id.org/valuesets/ExtremeWeatherEventEnum#EXTREME_PRECIPITATION> a owl:Class ;
