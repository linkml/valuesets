    valuesets:direct_use true .

<https://w3id.org/valuesets/GeothermalSystemType#HOT_DRY_ROCK> a owl:Class ;
    rdfs:label "HOT_DRY_ROCK" ;
    dcterms:title "Hot Dry Rock (HDR)" ;
    rdfs:subClassOf valuesets:GeothermalSystemType ;
    skos:altLabel "HDR" ;
    skos:definition "Geothermal system targeting hot basement rock lacking natural fluid or permeability, requiring artificial reservoir creation." .

<https://w3id.org/valuesets/GeothermalSystemType#HYDROTHERMAL> a owl:Class ;
    rdfs:label "HYDROTHERMAL" ;
    dcterms:title "Conventional Hydrothermal System" ;
    rdfs:subClassOf valuesets:GeothermalSystemType ;
