    rdfs:subClassOf valuesets:HydrogenStorageMethod ;
    skos:altLabel "CGH2" ;
    skos:definition "Storage of hydrogen as compressed gas at high pressure (350-700 bar) in pressure vessels." ;
    valuesets:maturity "commercial" ;
    valuesets:pressure_bar "350-700" .

<https://w3id.org/valuesets/HydrogenStorageMethod#CRYO_COMPRESSED> a owl:Class ;
    rdfs:label "CRYO_COMPRESSED" ;
    dcterms:title "Cryo-Compressed Storage" ;
    rdfs:subClassOf valuesets:HydrogenStorageMethod ;
    skos:altLabel "CcH2" ;
    skos:definition "Hybrid approach combining cryogenic cooling with high pressure for improved density." ;
    valuesets:maturity "emerging" .

<https://w3id.org/valuesets/HydrogenStorageMethod#LIQUID_HYDROGEN> a owl:Class ;
