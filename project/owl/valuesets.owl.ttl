<https://w3id.org/valuesets/GeothermalResourceTemperature#HIGH_TEMPERATURE> a owl:Class ;
    rdfs:label "HIGH_TEMPERATURE" ;
    dcterms:title "High Temperature Resource" ;
    rdfs:subClassOf valuesets:GeothermalResourceTemperature ;
