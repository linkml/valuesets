valuesets:NTPCarcinogenicityGroup a owl:Class ;
    rdfs:label "NTPCarcinogenicityGroup" ;
    dcterms:contributor <https://github.com/anthropics/claude-code>,
        ORCID:0000-0002-6601-2165 ;
    dcterms:title "NTP Carcinogenicity Group" ;
    bibo:status <STANDARD> ;
    rdfs:subClassOf valuesets:CarcinogenicitySchemaEnum ;
    owl:unionOf ( <https://w3id.org/valuesets/NTPCarcinogenicityGroup#KNOWN_CARCINOGEN> <https://w3id.org/valuesets/NTPCarcinogenicityGroup#RAHC> ) ;
    skos:definition "U.S. National Toxicology Program (NTP) Report on Carcinogens classifications. The NTP identifies and discusses agents, substances, mixtures, or exposure circumstances that may pose a carcinogenic hazard to human health." ;
    skos:inScheme valuesets:merged ;
    linkml:permissible_values <https://w3id.org/valuesets/NTPCarcinogenicityGroup#KNOWN_CARCINOGEN>,
        <https://w3id.org/valuesets/NTPCarcinogenicityGroup#RAHC> ;
    valuesets:publishers "https://ntp.niehs.nih.gov" ;
    valuesets:source "https://ntp.niehs.nih.gov/go/roc" ;
    valuesets:source_domain "environmental_health" ;
    valuesets:source_schema "carcinogenicity" ;
    valuesets:stewards "https://ntp.niehs.nih.gov" .

<https://w3id.org/valuesets/NTPCarcinogenicityGroup#KNOWN_CARCINOGEN> a owl:Class ;
    rdfs:label "KNOWN_CARCINOGEN" ;
    dcterms:title "Known To Be Human Carcinogen" ;
    rdfs:subClassOf valuesets:NTPCarcinogenicityGroup ;
    skos:definition "There is sufficient evidence of carcinogenicity from studies in humans, which indicates a causal relationship between exposure to the agent and human cancer." ;
    valuesets:abbreviation "K" ;
    valuesets:evidence "sufficient human evidence" ;
    valuesets:examples "arsenic, asbestos, benzene, vinyl chloride" .

<https://w3id.org/valuesets/NTPCarcinogenicityGroup#RAHC> a owl:Class ;
    rdfs:label "RAHC" ;
    dcterms:title "Reasonably Anticipated To Be Human Carcinogen" ;
    rdfs:subClassOf valuesets:NTPCarcinogenicityGroup ;
    skos:definition "There is limited evidence of carcinogenicity from studies in humans, which indicates that causal interpretation is credible but alternative explanations cannot be ruled out, OR there is sufficient evidence of carcinogenicity from studies in experimental animals." ;
    valuesets:abbreviation "RAHC" ;
    valuesets:evidence "limited human or sufficient animal evidence" ;
    valuesets:examples "lead compounds, styrene, trichloroethylene" .

