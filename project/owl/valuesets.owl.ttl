valuesets:ExposureFrequencyEnum a owl:Class ;
    rdfs:label "ExposureFrequencyEnum" ;
    dcterms:contributor <https://github.com/anthropics/claude-code>,
        ORCID:0000-0002-6601-2165 ;
    dcterms:title "Exposure Frequency" ;
    bibo:status <DRAFT> ;
    rdfs:subClassOf valuesets:ExposuresSchemaEnum ;
    owl:unionOf ( ExO:0000052 ExO:0000053 ) ;
    skos:definition "Temporal pattern of exposure occurrence" ;
    skos:inScheme valuesets:merged ;
    linkml:permissible_values ExO:0000052,
        ExO:0000053 ;
