    rdfs:label "HYDROTHERMAL_LIQUEFACTION" ;
    dcterms:title "Hydrothermal Liquefaction (HTL)" ;
    rdfs:subClassOf valuesets:BioconversionProcess ;
    skos:altLabel "HTL" ;
    skos:definition "Conversion of wet biomass to bio-crude using high temperature and pressure water." ;
    valuesets:category "thermochemical" ;
    valuesets:pressure_bar "100-200" ;
    valuesets:temperature_c "250-400" ;
    valuesets:wet_feedstock true .

<https://w3id.org/valuesets/BioconversionProcess#HYDROTREATING> a owl:Class ;
    rdfs:label "HYDROTREATING" ;
    dcterms:title "Hydrotreating/Hydroprocessing" ;
    rdfs:subClassOf valuesets:BioconversionProcess ;
    skos:altLabel "Hydroprocessing" ;
    skos:definition "Catalytic reaction of lipids with hydrogen to produce hydrocarbon fuels." ;
    valuesets:category "thermochemical" ;
    valuesets:products "renewable_diesel,SAF" .

<https://w3id.org/valuesets/BioconversionProcess#PYROLYSIS> a owl:Class ;
    rdfs:label "PYROLYSIS" ;
    dcterms:title "Pyrolysis" ;
    rdfs:subClassOf valuesets:BioconversionProcess ;
    skos:definition "Thermal decomposition of biomass in the absence of oxygen to produce bio-oil, syngas, and biochar." ;
    valuesets:category "thermochemical" ;
    valuesets:products "bio_oil,syngas,biochar" ;
    valuesets:temperature_c "400-600" .

<https://w3id.org/valuesets/BioconversionProcess#TRANSESTERIFICATION> a owl:Class ;
    rdfs:label "TRANSESTERIFICATION" ;
    dcterms:title "Transesterification" ;
    rdfs:subClassOf valuesets:BioconversionProcess ;
    skos:definition "Chemical reaction of triglycerides with alcohol to produce fatty acid esters (biodiesel) and glycerol." ;
    valuesets:category "chemical" ;
    valuesets:products "biodiesel" .

<https://w3id.org/valuesets/BioextractionMethodType#BIOACCUMULATION> a owl:Class ;
    rdfs:label "BIOACCUMULATION" ;
    rdfs:subClassOf valuesets:BioextractionMethodType ;
    skos:definition "Active uptake and intracellular concentration of metals by living organisms" ;
    valuesets:mechanism "metabolically driven intracellular uptake" ;
    valuesets:organisms "bacteria, fungi, algae" .

<https://w3id.org/valuesets/BioextractionMethodType#BIOFLOTATION> a owl:Class ;
    rdfs:label "BIOFLOTATION" ;
    rdfs:subClassOf valuesets:BioextractionMethodType ;
    skos:definition "Use of microorganisms or biosurfactants to selectively separate mineral particles by flotation" ;
    valuesets:mechanism "selective surface modification" ;
    valuesets:organisms "Mycobacterium, Bacillus" .

<https://w3id.org/valuesets/BioextractionMethodType#BIOPRECIPITATION> a owl:Class ;
    rdfs:label "BIOPRECIPITATION" ;
    rdfs:subClassOf valuesets:BioextractionMethodType ;
    skos:broadMatch CHMO:0001688 ;
    skos:definition "Microbially mediated precipitation of metals as insoluble compounds such as sulfides or phosphates" ;
    valuesets:mechanism "sulfate reduction, phosphate release" ;
    valuesets:products "metal sulfides, metal phosphates" .

<https://w3id.org/valuesets/BioextractionMethodType#BIOSORPTION> a owl:Class ;
    rdfs:label "BIOSORPTION" ;
    rdfs:subClassOf valuesets:BioextractionMethodType ;
    skos:definition "Passive binding of metal ions to the surface of biological materials such as microbial biomass" ;
    valuesets:materials "dead biomass, algae, fungi" ;
    valuesets:mechanism "surface complexation, ion exchange" .

<https://w3id.org/valuesets/BioextractionMethodType#HEAP_BIOLEACHING> a owl:Class ;
    rdfs:label "HEAP_BIOLEACHING" ;
    rdfs:subClassOf valuesets:BioextractionMethodType ;
    skos:broadMatch CHMO:0001681 ;
    skos:definition "Biological leaching of metals from crushed ore stacked in heaps irrigated with acidic microbial solutions" ;
    valuesets:organisms "Acidithiobacillus ferrooxidans, Acidithiobacillus thiooxidans" ;
    valuesets:scale "industrial" .

<https://w3id.org/valuesets/BioextractionMethodType#IN_SITU_BIOLEACHING> a owl:Class ;
    rdfs:label "IN_SITU_BIOLEACHING" ;
    rdfs:subClassOf valuesets:BioextractionMethodType ;
    skos:broadMatch CHMO:0001681 ;
    skos:definition "Biological leaching of metals directly in the ore body without excavation" ;
    valuesets:advantage "minimal surface disturbance" ;
    valuesets:application "low-grade deposits" .

<https://w3id.org/valuesets/BioextractionMethodType#PHYTOMINING> a owl:Class ;
    rdfs:label "PHYTOMINING" ;
    rdfs:subClassOf valuesets:BioextractionMethodType ;
    skos:definition "Use of hyperaccumulator plants to extract metals from soil or mining waste for recovery" ;
    valuesets:metals "nickel, zinc, thallium" ;
    valuesets:organisms "Alyssum, Thlaspi, Pteris" .

<https://w3id.org/valuesets/BioextractionMethodType#STIRRED_TANK_BIOLEACHING> a owl:Class ;
    rdfs:label "STIRRED_TANK_BIOLEACHING" ;
    rdfs:subClassOf valuesets:BioextractionMethodType ;
    skos:broadMatch CHMO:0001681 ;
    skos:definition "Biological leaching of metals in agitated tank reactors with controlled conditions" ;
    valuesets:organisms "Acidithiobacillus, Leptospirillum" ;
    valuesets:scale "industrial, pilot" .

