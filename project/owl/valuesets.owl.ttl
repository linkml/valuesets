<http://id.loc.gov/vocabulary/preservation/objectCategory/bit> a owl:Class ;
    rdfs:label "BITSTREAM" ;
    rdfs:subClassOf valuesets:DigitalObjectCategory ;
    skos:definition """Contiguous or non-contiguous data within a file that has meaningful
properties for preservation purposes. A bitstream cannot be transformed
into a standalone file without the addition of file structure.
""" .

<http://id.loc.gov/vocabulary/preservation/objectCategory/fil> a owl:Class ;
    rdfs:label "FILE" ;
    rdfs:subClassOf valuesets:DigitalObjectCategory ;
    skos:definition """A named and ordered sequence of bytes that is known to an operating
system. A file can be zero or more bytes and has a file format,
access permissions, and other file system characteristics.
""" .

<http://id.loc.gov/vocabulary/preservation/objectCategory/int> a owl:Class ;
    rdfs:label "INTELLECTUAL_ENTITY" ;
    dcterms:title "Intellectual Entity" ;
    rdfs:subClassOf valuesets:DigitalObjectCategory ;
    skos:definition """A coherent set of content that is reasonably described as a unit.
Examples include a book, a photograph, a database, or a software
application. An intellectual entity may contain other intellectual
entities.
""" .

<http://id.loc.gov/vocabulary/preservation/objectCategory/rep> a owl:Class ;
    rdfs:label "REPRESENTATION" ;
    rdfs:subClassOf valuesets:DigitalObjectCategory ;
    skos:definition """The set of files, including structural metadata, needed for a
complete and reasonable rendition of an intellectual entity.
A digital object may have multiple representations.
""" .

<http://id.loc.gov/vocabulary/preservation/preservationLevelRole/cap> a owl:Class ;
    rdfs:label "CAPABILITY" ;
    rdfs:subClassOf valuesets:PreservationLevelRole ;
    skos:definition """The preservation level that the repository is capable of providing
based on its technical infrastructure and resources.
""" .

<http://id.loc.gov/vocabulary/preservation/preservationLevelRole/int> a owl:Class ;
    rdfs:label "INTENTION" ;
    rdfs:subClassOf valuesets:PreservationLevelRole ;
