valuesets:AnomalyDetectionEnum a owl:Class ;
    rdfs:label "AnomalyDetectionEnum" ;
    dcterms:contributor <https://github.com/anthropics/claude-code>,
        ORCID:0000-0002-6601-2165 ;
    dcterms:title "Anomaly Detection" ;
    bibo:status <DRAFT> ;
    rdfs:subClassOf valuesets:BinaryClassificationSchemaEnum ;
    owl:unionOf ( NCIt:C14165 STATO:0000036 ) ;
    skos:definition "Labels for anomaly detection tasks" ;
    skos:inScheme valuesets:merged ;
    linkml:permissible_values NCIt:C14165,
        STATO:0000036 ;
    valuesets:source_domain "data_science" ;
    valuesets:source_schema "binary_classification" .

<https://w3id.org/valuesets/AquiferType#ALLUVIAL> a owl:Class ;
    rdfs:label "ALLUVIAL" ;
    rdfs:subClassOf valuesets:AquiferType ;
    skos:definition "An aquifer composed of unconsolidated alluvial deposits such as sand and gravel deposited by rivers" .

<https://w3id.org/valuesets/AquiferType#ARTESIAN> a owl:Class ;
    rdfs:label "ARTESIAN" ;
    rdfs:subClassOf valuesets:AquiferType ;
    skos:definition "A confined aquifer in which the hydraulic pressure causes water to rise above the top of the aquifer" .

<https://w3id.org/valuesets/AquiferType#CONFINED> a owl:Class ;
    rdfs:label "CONFINED" ;
    rdfs:subClassOf valuesets:AquiferType ;
    skos:definition "An aquifer bounded above and below by impermeable layers, under pressure greater than atmospheric" .

<https://w3id.org/valuesets/AquiferType#FRACTURED_ROCK> a owl:Class ;
    rdfs:label "FRACTURED_ROCK" ;
    rdfs:subClassOf valuesets:AquiferType ;
    skos:definition "An aquifer in which groundwater flows primarily through fractures in otherwise low-permeability rock" .

<https://w3id.org/valuesets/AquiferType#KARST> a owl:Class ;
    rdfs:label "KARST" ;
    rdfs:subClassOf valuesets:AquiferType ;
    skos:broadMatch ENVO:00000175 ;
    skos:definition "An aquifer in soluble rock such as limestone where flow occurs through dissolution-enlarged conduits and fractures" .

<https://w3id.org/valuesets/AquiferType#PERCHED> a owl:Class ;
    rdfs:label "PERCHED" ;
    rdfs:subClassOf valuesets:AquiferType ;
    skos:definition "A localized unconfined aquifer above the regional water table, supported by a low-permeability layer" .

<https://w3id.org/valuesets/AquiferType#SEMI_CONFINED> a owl:Class ;
    rdfs:label "SEMI_CONFINED" ;
    rdfs:subClassOf valuesets:AquiferType ;
    skos:definition "An aquifer partially bounded by layers of lower permeability that allow some vertical leakage" .

<https://w3id.org/valuesets/AquiferType#UNCONFINED> a owl:Class ;
    rdfs:label "UNCONFINED" ;
    rdfs:subClassOf valuesets:AquiferType ;
    skos:definition "An aquifer whose upper boundary is the water table, open to atmospheric pressure" .

