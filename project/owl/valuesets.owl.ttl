<https://w3id.org/valuesets/EPAIRISCarcinogenicityGroup#CARCINOGENIC_TO_HUMANS> a owl:Class ;
    rdfs:label "CARCINOGENIC_TO_HUMANS" ;
    dcterms:title "Carcinogenic to Humans" ;
    rdfs:subClassOf valuesets:EPAIRISCarcinogenicityGroup ;
    skos:definition "Strong evidence of human carcinogenicity. This descriptor is appropriate when there is convincing epidemiologic evidence of a causal association between human exposure and cancer." ;
    valuesets:evidence "convincing epidemiologic evidence" ;
    valuesets:legacy_group "A" .

<https://w3id.org/valuesets/EPAIRISCarcinogenicityGroup#GROUP_A> a owl:Class ;
    rdfs:label "GROUP_A" ;
    dcterms:title "Group A - Human Carcinogen (Legacy)" ;
    rdfs:subClassOf valuesets:EPAIRISCarcinogenicityGroup ;
    skos:definition "Legacy EPA classification. Sufficient evidence from epidemiologic studies to support a causal association between exposure and cancer." ;
    valuesets:status "legacy" ;
    valuesets:superseded_by "CARCINOGENIC_TO_HUMANS" .

<https://w3id.org/valuesets/EPAIRISCarcinogenicityGroup#GROUP_B1> a owl:Class ;
    rdfs:label "GROUP_B1" ;
    dcterms:title "Group B1 - Probable Human Carcinogen (Legacy)" ;
    rdfs:subClassOf valuesets:EPAIRISCarcinogenicityGroup ;
    skos:definition "Legacy EPA classification. Limited evidence of carcinogenicity from epidemiologic studies." ;
    valuesets:status "legacy" ;
    valuesets:superseded_by "LIKELY_CARCINOGENIC" .

<https://w3id.org/valuesets/EPAIRISCarcinogenicityGroup#GROUP_B2> a owl:Class ;
    rdfs:label "GROUP_B2" ;
    dcterms:title "Group B2 - Probable Human Carcinogen (Legacy)" ;
    rdfs:subClassOf valuesets:EPAIRISCarcinogenicityGroup ;
    skos:definition "Legacy EPA classification. Sufficient evidence from animal studies and inadequate evidence from epidemiologic studies." ;
    valuesets:status "legacy" ;
    valuesets:superseded_by "LIKELY_CARCINOGENIC" .

<https://w3id.org/valuesets/EPAIRISCarcinogenicityGroup#GROUP_C> a owl:Class ;
    rdfs:label "GROUP_C" ;
    dcterms:title "Group C - Possible Human Carcinogen (Legacy)" ;
    rdfs:subClassOf valuesets:EPAIRISCarcinogenicityGroup ;
    skos:definition "Legacy EPA classification. Limited evidence of carcinogenicity in animals in the absence of human data." ;
    valuesets:status "legacy" ;
    valuesets:superseded_by "SUGGESTIVE_EVIDENCE" .

<https://w3id.org/valuesets/EPAIRISCarcinogenicityGroup#GROUP_D> a owl:Class ;
    rdfs:label "GROUP_D" ;
    dcterms:title "Group D - Not Classifiable (Legacy)" ;
    rdfs:subClassOf valuesets:EPAIRISCarcinogenicityGroup ;
    skos:definition "Legacy EPA classification. Inadequate human and animal evidence of carcinogenicity or no data available." ;
    valuesets:status "legacy" ;
    valuesets:superseded_by "INADEQUATE_INFORMATION" .

<https://w3id.org/valuesets/EPAIRISCarcinogenicityGroup#GROUP_E> a owl:Class ;
    rdfs:label "GROUP_E" ;
    dcterms:title "Group E - Evidence of Non-Carcinogenicity (Legacy)" ;
    rdfs:subClassOf valuesets:EPAIRISCarcinogenicityGroup ;
    skos:definition "Legacy EPA classification. No evidence of carcinogenicity in at least two adequate animal tests or in adequate epidemiologic and animal studies." ;
    valuesets:status "legacy" ;
    valuesets:superseded_by "NOT_LIKELY_CARCINOGENIC" .

<https://w3id.org/valuesets/EPAIRISCarcinogenicityGroup#INADEQUATE_INFORMATION> a owl:Class ;
    rdfs:label "INADEQUATE_INFORMATION" ;
    dcterms:title "Inadequate Information to Assess Carcinogenic Potential" ;
    rdfs:subClassOf valuesets:EPAIRISCarcinogenicityGroup ;
    skos:definition "Available data are inadequate for an assessment of human carcinogenic potential." ;
    valuesets:evidence "inadequate data" ;
    valuesets:legacy_group "D" .

<https://w3id.org/valuesets/EPAIRISCarcinogenicityGroup#LIKELY_CARCINOGENIC> a owl:Class ;
    rdfs:label "LIKELY_CARCINOGENIC" ;
    dcterms:title "Likely to Be Carcinogenic to Humans" ;
    rdfs:subClassOf valuesets:EPAIRISCarcinogenicityGroup ;
    skos:definition "Evidence is adequate to demonstrate carcinogenic potential to humans but does not reach the weight of evidence for Carcinogenic to Humans." ;
    valuesets:evidence "adequate evidence" ;
    valuesets:legacy_group "B1/B2" .

<https://w3id.org/valuesets/EPAIRISCarcinogenicityGroup#NOT_LIKELY_CARCINOGENIC> a owl:Class ;
    rdfs:label "NOT_LIKELY_CARCINOGENIC" ;
    dcterms:title "Not Likely to Be Carcinogenic to Humans" ;
    rdfs:subClassOf valuesets:EPAIRISCarcinogenicityGroup ;
