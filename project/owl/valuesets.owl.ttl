    valuesets:flexibility "reduced flexibility" ;
    valuesets:internal "internal production" ;
    valuesets:investment "significant investment" .

valuesets:SpamClassificationEnum a owl:Class ;
    rdfs:label "SpamClassificationEnum" ;
    dcterms:contributor <https://github.com/anthropics/claude-code>,
        ORCID:0000-0002-6601-2165 ;
    dcterms:title "Spam Classification" ;
    bibo:status <DRAFT> ;
    rdfs:subClassOf valuesets:BinaryClassificationSchemaEnum ;
    owl:unionOf ( <https://w3id.org/valuesets/SpamClassificationEnum#SPAM> <https://w3id.org/valuesets/SpamClassificationEnum#HAM> ) ;
    skos:definition "Standard labels for spam/ham email classification" ;
    skos:inScheme valuesets:merged ;
    linkml:permissible_values <https://w3id.org/valuesets/SpamClassificationEnum#HAM>,
        <https://w3id.org/valuesets/SpamClassificationEnum#SPAM> ;
    valuesets:source_domain "data_science" ;
    valuesets:source_schema "binary_classification" .

<https://w3id.org/valuesets/SpamClassificationEnum#HAM> a owl:Class ;
    rdfs:label "HAM" ;
    rdfs:subClassOf valuesets:SpamClassificationEnum ;
    skos:altLabel "0",
        "legitimate",
        "not_spam" ;
    skos:definition "Legitimate, wanted message" ;
    valuesets:note "No appropriate ontology term found for ham concept" .

<https://w3id.org/valuesets/SpamClassificationEnum#SPAM> a owl:Class ;
    rdfs:label "SPAM" ;
    rdfs:subClassOf valuesets:SpamClassificationEnum ;
    skos:altLabel "1",
        "junk" ;
    skos:definition "Unwanted or unsolicited message" ;
    valuesets:note "No appropriate ontology term found for spam concept" .

<https://w3id.org/valuesets/SpatialRelationship#BETWEEN> a owl:Class ;
    rdfs:label "BETWEEN" ;
    rdfs:subClassOf valuesets:SpatialRelationship ;
    skos:definition "In the space separating two structures" ;
    valuesets:note "requires two reference points" .

<https://w3id.org/valuesets/SpatialRelationship#WITHIN> a owl:Class ;
    rdfs:label "WITHIN" ;
    rdfs:subClassOf valuesets:SpatialRelationship ;
    skos:definition "Inside or contained by" ;
    valuesets:inverse_of "contains" .

<https://w3id.org/valuesets/SpatialResolutionEnum#ADDRESS_GEOCODED> a owl:Class ;
