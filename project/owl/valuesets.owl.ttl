    owl:unionOf ( <https://w3id.org/valuesets/ChurnClassificationEnum#RETAINED> <https://w3id.org/valuesets/ChurnClassificationEnum#CHURNED> ) ;
    skos:definition "Customer churn prediction labels" ;
    skos:inScheme valuesets:merged ;
    linkml:permissible_values <https://w3id.org/valuesets/ChurnClassificationEnum#CHURNED>,
        <https://w3id.org/valuesets/ChurnClassificationEnum#RETAINED> ;
    valuesets:source_domain "data_science" ;
    valuesets:source_schema "binary_classification" .

