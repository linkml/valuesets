    rdfs:subClassOf valuesets:ReservoirCharacterizationMethodType ;
    skos:definition "Interpretation of seismic survey data to map subsurface geological structures and properties" ;
    valuesets:types "2D seismic, 3D seismic, 4D time-lapse" .

<https://w3id.org/valuesets/ReservoirCharacterizationMethodType#TRACER_TEST> a owl:Class ;
