    skos:narrowMatch <http://sweetontology.net/procPhysical/Gasification> ;
    valuesets:feedstock "biomass" ;
    valuesets:renewable true .

<https://w3id.org/valuesets/HydrogenProductionMethod#METHANE_PYROLYSIS> a owl:Class ;
    rdfs:label "METHANE_PYROLYSIS" ;
    dcterms:title "Methane Pyrolysis" ;
    rdfs:subClassOf valuesets:HydrogenProductionMethod ;
    skos:altLabel "Thermal Cracking" ;
    skos:definition "Thermal decomposition of methane into hydrogen and solid carbon without oxygen. Produces no direct CO2." ;
    valuesets:byproduct "solid_carbon" ;
    valuesets:feedstock "natural_gas" .

<https://w3id.org/valuesets/HydrogenProductionMethod#PARTIAL_OXIDATION> a owl:Class ;
    rdfs:label "PARTIAL_OXIDATION" ;
    dcterms:title "Partial Oxidation (POX)" ;
    rdfs:subClassOf valuesets:HydrogenProductionMethod ;
    skos:altLabel "POX" ;
    skos:definition "Exothermic process reacting hydrocarbons with limited oxygen to produce hydrogen and carbon monoxide." .

<https://w3id.org/valuesets/HydrogenProductionMethod#PEM_ELECTROLYSIS> a owl:Class ;
    rdfs:label "PEM_ELECTROLYSIS" ;
    dcterms:title "PEM Electrolysis" ;
    rdfs:subClassOf valuesets:HydrogenProductionMethod ;
    skos:altLabel "PEMEC",
        "Polymer Electrolyte Membrane Electrolysis" ;
    skos:definition "Proton Exchange Membrane electrolysis using solid polymer electrolyte. Higher efficiency, faster response." ;
    valuesets:electrolyte "polymer_membrane" ;
    valuesets:maturity "commercial" .

<https://w3id.org/valuesets/HydrogenProductionMethod#PHOTOELECTROCHEMICAL> a owl:Class ;
    rdfs:label "PHOTOELECTROCHEMICAL" ;
    dcterms:title "Photoelectrochemical Water Splitting" ;
    rdfs:subClassOf valuesets:HydrogenProductionMethod ;
    skos:altLabel "PEC" ;
    skos:definition "Direct conversion of sunlight to hydrogen using specialized semiconductor materials in contact with water." ;
    valuesets:maturity "research" .

<https://w3id.org/valuesets/HydrogenProductionMethod#SOLID_OXIDE_ELECTROLYSIS> a owl:Class ;
    rdfs:label "SOLID_OXIDE_ELECTROLYSIS" ;
    dcterms:title "Solid Oxide Electrolysis (SOEC)" ;
    rdfs:subClassOf valuesets:HydrogenProductionMethod ;
    skos:altLabel "SOEC" ;
    skos:definition "High temperature electrolysis using solid ceramic electrolyte. Higher efficiency when waste heat is available." ;
    valuesets:electrolyte "solid_oxide" ;
    valuesets:maturity "emerging" ;
    valuesets:temperature_c "700-850" .

<https://w3id.org/valuesets/HydrogenProductionMethod#STEAM_METHANE_REFORMING> a owl:Class ;
    rdfs:label "STEAM_METHANE_REFORMING" ;
    dcterms:title "Steam Methane Reforming (SMR)" ;
    rdfs:subClassOf valuesets:HydrogenProductionMethod ;
    skos:altLabel "SMR" ;
    skos:definition "High temperature steam reacts with methane to produce hydrogen, carbon monoxide, and carbon dioxide." ;
    valuesets:dominant_method true ;
    valuesets:feedstock "natural_gas" ;
    valuesets:temperature_c "700-1000" .

<https://w3id.org/valuesets/HydrogenProductionMethod#THERMOCHEMICAL_WATER_SPLITTING> a owl:Class ;
    rdfs:label "THERMOCHEMICAL_WATER_SPLITTING" ;
    dcterms:title "Thermochemical Water Splitting" ;
    rdfs:subClassOf valuesets:HydrogenProductionMethod ;
    skos:definition "Using high temperatures from concentrated solar or nuclear to drive chemical cycles that split water." ;
    valuesets:maturity "research" ;
    valuesets:temperature_c "500-2000" .

<https://w3id.org/valuesets/HydrogenProductionMethod#WATER_ELECTROLYSIS> a owl:Class ;
    rdfs:label "WATER_ELECTROLYSIS" ;
    dcterms:title "Water Electrolysis" ;
    rdfs:subClassOf valuesets:HydrogenProductionMethod ;
    skos:altLabel "Electrolysis" ;
    skos:closeMatch <http://sweetontology.net/procChemical/Electrolysis> ;
    skos:definition "Splitting water into hydrogen and oxygen using electrical current. Can be powered by various energy sources." .

<https://w3id.org/valuesets/HydrogenStorageMethod#CHEMICAL_HYDRIDE> a owl:Class ;
    rdfs:label "CHEMICAL_HYDRIDE" ;
    dcterms:title "Chemical Hydride Storage" ;
    rdfs:subClassOf valuesets:HydrogenStorageMethod ;
    skos:altLabel "LOHC",
        "Liquid Organic Hydrogen Carrier" ;
