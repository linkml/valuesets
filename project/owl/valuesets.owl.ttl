<https://w3id.org/valuesets/HydrogenApplication#BLENDING_NATURAL_GAS> a owl:Class ;
    rdfs:label "BLENDING_NATURAL_GAS" ;
    dcterms:title "Natural Gas Blending" ;
    rdfs:subClassOf valuesets:HydrogenApplication ;
