<https://w3id.org/valuesets/GeothermalReservoirType#FAULT_CONTROLLED> a owl:Class ;
    rdfs:label "FAULT_CONTROLLED" ;
    dcterms:title "Fault-Controlled Reservoir" ;
    rdfs:subClassOf valuesets:GeothermalReservoirType ;
